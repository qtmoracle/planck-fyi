---
import OperatorLayout from "../../../layouts/OperatorLayout.astro";
import RequestIntake from "../../../components/RequestIntake.astro";
import type { Operator } from "../../../data/operators";

interface Props {
  operator: Operator;
}

const { operator } = Astro.props;
---

<OperatorLayout
  title={operator.name}
  operatorName={operator.name}
  operatorLogo={operator.logo}
  region={operator.regionName}
  bookingHref={operator.bookingHref}
>
  <main>
    <section class="relative overflow-hidden min-h-[75vh] py-16 sm:py-24">
      <div class="absolute inset-0 -z-10">
        <div class="h-full w-full bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.06),transparent_60%)]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg/95 to-bg"></div>
      </div>

      <div class="mx-auto max-w-content px-4 sm:px-6">
        <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
          <div class="lg:col-span-8">
            <p class="text-xs tracking-wide text-text/70">
              on-site execution · {operator.regionName.toLowerCase()}
            </p>

            <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tightest leading-tight">
              consistent care.<br />documented results.
            </h1>

            <p class="mt-7 max-w-2xl text-lg text-text/70 leading-relaxed">
              structured property maintenance executed with clear scope, before/after
              documentation, and a defined job lifecycle from dispatch to completion.
            </p>

            <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
              <a
                href={operator.bookingHref}
                class="inline-flex items-center justify-center border border-border px-8 py-4 hover:border-accent transition-colors"
              >
                request service
              </a>

              <a
                href="#services"
                class="inline-flex items-center justify-center px-8 py-4 text-sm text-text hover:text-accent transition-colors"
              >
                view service options →
              </a>
            </div>

            <div class="mt-10 grid gap-3 sm:grid-cols-3 max-w-2xl">
              <div class="rounded-xl border border-border bg-bg/50 p-4 backdrop-blur-sm">
                <p class="text-xs tracking-wide text-text/70">execution</p>
                <p class="mt-2 text-sm text-text">fixed scope. defined deliverables.</p>
              </div>
              <div class="rounded-xl border border-border bg-bg/50 p-4 backdrop-blur-sm">
                <p class="text-xs tracking-wide text-text/70">evidence</p>
                <p class="mt-2 text-sm text-text">before + after. every job.</p>
              </div>
              <div class="rounded-xl border border-border bg-bg/50 p-4 backdrop-blur-sm">
                <p class="text-xs tracking-wide text-text/70">record</p>
                <p class="mt-2 text-sm text-text">structured service record on completion.</p>
              </div>
            </div>
          </div>

          <aside class="lg:col-span-4">
            <div class="border border-border p-8 space-y-6 bg-bg/70 backdrop-blur-sm">
              <div>
                <p class="text-xs tracking-wide text-text/70">service model</p>
                <p class="mt-2 text-sm text-text">
                  requests are reviewed by schedule and property scope.
                  capacity is managed intentionally.
                </p>
              </div>

              <div class="border-t border-border pt-6">
                <p class="text-xs tracking-wide text-text/70">what we do</p>
                <ul class="mt-3 space-y-2 text-sm text-text/70 leading-relaxed">
                  <li>• mowing (standard + detail pass)</li>
                  <li>• trimming (edges, borders, obstacles)</li>
                  <li>• edging (defined lines, clean cuts)</li>
                  <li>• cleanup (clippings, debris, haul-out)</li>
                </ul>
              </div>

              <div class="border-t border-border pt-6">
                <p class="text-xs tracking-wide text-text/70">what we don't do</p>
                <ul class="mt-3 space-y-2 text-sm text-text/70 leading-relaxed">
                  <li>• landscape design or re-grading</li>
                  <li>• irrigation installation or repair</li>
                  <li>• tree removal or major demolition</li>
                </ul>
              </div>

              <div class="border-t border-border pt-6">
                <p class="text-xs tracking-wide text-text/70">standards</p>
                <ul class="mt-3 space-y-2 text-sm text-text/70 leading-relaxed">
                  <li>• property access confirmed before dispatch.</li>
                  <li>• before/after photos captured on every job.</li>
                  <li>• service record issued on completion.</li>
                </ul>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section id="services" class="py-24 border-t border-border">
      <div class="mx-auto max-w-content px-4 sm:px-6">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <h2 class="text-3xl font-semibold">property maintenance services</h2>
            <p class="mt-4 max-w-3xl text-muted leading-relaxed">
              structured execution for residential and commercial properties.
              each job follows a defined lifecycle — scheduled, dispatched, executed, documented.
            </p>
          </div>

          <a
            href={operator.bookingHref}
            class="inline-flex items-center justify-center border border-border px-6 py-3 hover:border-accent transition-colors"
          >
            request →
          </a>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <div class="border border-border p-6 space-y-3">
            <p class="text-xs tracking-wide text-text/70">service</p>
            <p class="text-lg font-semibold">mowing</p>
            <p class="text-sm text-text/70 leading-relaxed">
              standard cut with detail pass. height set per property spec.
              consistent pass pattern. clippings managed.
            </p>
          </div>

          <div class="border border-border p-6 space-y-3">
            <p class="text-xs tracking-wide text-text/70">service</p>
            <p class="text-lg font-semibold">trimming</p>
            <p class="text-sm text-text/70 leading-relaxed">
              edges, borders, and obstacle clearance. attention to fence lines,
              beds, and structures.
            </p>
          </div>

          <div class="border border-border p-6 space-y-3">
            <p class="text-xs tracking-wide text-text/70">service</p>
            <p class="text-lg font-semibold">edging</p>
            <p class="text-sm text-text/70 leading-relaxed">
              defined hard lines along driveways, walkways, and curbs.
              clean separation between turf and hardscape.
            </p>
          </div>

          <div class="border border-border p-6 space-y-3">
            <p class="text-xs tracking-wide text-text/70">service</p>
            <p class="text-lg font-semibold">cleanup</p>
            <p class="text-sm text-text/70 leading-relaxed">
              clippings blown clear. debris collected. property left in
              documented condition before departure.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 border-t border-border">
      <div class="mx-auto max-w-content px-4 sm:px-6">
        <div class="max-w-3xl">
          <h2 class="text-3xl font-semibold">request service</h2>

          <p class="mt-6 text-muted leading-relaxed">
            Submit a request with your property address, service type, and any relevant
            access notes. Requests are reviewed and scheduled based on current capacity.
          </p>

          <p class="mt-4 text-muted leading-relaxed">
            Before/after documentation is captured on every job. A service record is issued
            on completion.
          </p>

          <div class="mt-10">
            <RequestIntake />
          </div>
        </div>
      </div>
    </section>
  </main>
</OperatorLayout>
