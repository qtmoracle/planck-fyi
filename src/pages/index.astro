---
import BaseLayout from "../layouts/BaseLayout.astro";
import { operators } from "../data/operators";
import { surfaces } from "../data/surfaces";

const liveSurfaces = surfaces.filter((s) => s.status === "live");
---

<BaseLayout title="Planck Service Router">
  <main class="py-28">
    <div class="mx-auto max-w-content px-4 sm:px-6">

      <section class="max-w-3xl">
        <p class="text-xs tracking-wide text-text/70">
          planck routing infrastructure
        </p>

        <h1 class="mt-4 text-5xl sm:text-6xl font-semibold tracking-tightest leading-tight">
          service.<br />
          infrastructure.
        </h1>

        <p class="mt-8 text-lg text-muted leading-relaxed">
          Planck helps customers find trusted independent operators executing structured, documentation-first services.
        </p>

        <div class="mt-12 flex flex-col sm:flex-row gap-4">
          <a
            href="/operators"
            class="inline-flex items-center justify-center border border-border px-8 py-4 hover:border-accent transition-colors"
          >
            browse operators
          </a>

          <a
            href="/router"
            class="inline-flex items-center justify-center px-8 py-4 text-text hover:text-accent transition-colors"
          >
            search the network →
          </a>
        </div>
      </section>

      <section class="mt-32 border-t border-border pt-20">
        <h2 class="text-2xl font-semibold">
          active surfaces
        </h2>

        <p class="mt-4 text-muted max-w-2xl leading-relaxed">
          surfaces represent service categories operating on the planck routing network.
        </p>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {liveSurfaces.map((surface) => (
            <a
              href={`/surfaces/${surface.slug}`}
              class="border border-border p-6 hover:border-accent transition-colors"
            >
              <p class="text-lg font-medium">{surface.name.toLowerCase()}</p>

              <p class="mt-2 text-sm text-text/70">
                {surface.description}
              </p>

              <p class="mt-6 text-sm text-accent">
                view surface →
              </p>
            </a>
          ))}
        </div>
      </section>

      <section class="mt-32 border-t border-border pt-20">
        <h2 class="text-2xl font-semibold">
          the network
        </h2>

        <p class="mt-6 text-muted max-w-3xl leading-relaxed">
          planck is routing infrastructure connecting customers with independent
          operators executing standardized service protocols.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          <div class="border border-border p-4">
            <p class="text-xs tracking-wide text-text/70">operators</p>
            <p class="mt-2 text-lg">{operators.length}</p>
          </div>

          <div class="border border-border p-4">
            <p class="text-xs tracking-wide text-text/70">surfaces</p>
            <p class="mt-2 text-lg">{liveSurfaces.length}</p>
          </div>

          <div class="border border-border p-4">
            <p class="text-xs tracking-wide text-text/70">infrastructure</p>
            <p class="mt-2 text-lg">active</p>
          </div>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>
