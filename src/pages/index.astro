---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Planck Surface Engineers">
  <main>
    <section class="py-24">
      <div class="mx-auto max-w-content px-6 text-center">
        <h1 class="text-5xl font-semibold tracking-tightest leading-tight">
          Surface Discipline.<br />Preserved Value.
        </h1>

        <p class="mt-6 mx-auto max-w-xl text-muted leading-relaxed">
          Structured execution for vehicles that deserve precision.
        </p>

        <div class="mt-10">
          <a
            href="#request"
            class="inline-block border border-border px-8 py-3 hover:border-accent transition-colors"
          >
            Request Appointment
          </a>
        </div>

        <p class="mt-8 text-sm text-muted">
          Appointment-only · Pinecrest · Coral Gables · South Miami · Kendall
        </p>
      </div>
    </section>

    <section id="request" class="py-24 border-t border-border">
      <div class="mx-auto max-w-content px-6">
        <h2 class="text-2xl font-semibold">Request Appointment</h2>
        <p class="mt-3 max-w-2xl text-muted leading-relaxed">
          Submission does not guarantee an appointment. Confirmation is issued upon review.
        </p>

        <div class="mt-8 border border-border p-6">
          <p class="text-muted">
            Next: we decide intake method (structured form vs Text/Email buttons).
          </p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
