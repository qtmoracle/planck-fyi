---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceMatrix from "../components/ServiceMatrix.astro";
import FieldDocumentation from "../components/FieldDocumentation.astro";
import RequestIntake from "../components/RequestIntake.astro";
---

<BaseLayout title="Planck Surface Engineers">
  <main>

    <!-- HERO + RIGHT RAIL -->
    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-content px-4 sm:px-6">
        <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
          <div class="lg:col-span-8">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tightest leading-tight">
              Surface Discipline.<br />Preserved Value.
            </h1>

            <p class="mt-8 max-w-2xl text-lg text-muted leading-relaxed">
              Structured execution for vehicles that deserve precision.
            </p>

            <div class="mt-12">
              <a
                href="#request"
                class="inline-block border border-border px-10 py-4 hover:border-accent transition-colors"
              >
                Request Appointment
              </a>
            </div>

            <p class="mt-10 text-sm text-muted">
              Appointment-only · Pinecrest · Coral Gables · South Miami · Kendall
            </p>
          </div>

          <aside class="lg:col-span-4">
            <div class="border border-border p-8 space-y-6">
              <div>
                <p class="text-xs uppercase tracking-wider text-muted">Availability</p>
                <p class="mt-2 text-sm text-text">
                  Weekly capacity is intentionally limited.
                </p>
              </div>

              <div class="border-t border-border pt-6">
                <p class="text-xs uppercase tracking-wider text-muted">Service Area</p>
                <p class="mt-2 text-sm text-text">
                  Pinecrest · Coral Gables · South Miami · Kendall
                </p>
              </div>

              <div class="border-t border-border pt-6">
                <p class="text-xs uppercase tracking-wider text-muted">Standards</p>
                <ul class="mt-2 space-y-2 text-sm text-muted leading-relaxed">
                  <li>Approval is subject to condition + schedule alignment.</li>
                  <li>Fixed protocol pricing. No scope negotiation.</li>
                  <li>Work is scheduled to protect standards.</li>
                </ul>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="py-24 border-t border-border">
      <div class="mx-auto max-w-content px-4 sm:px-6">
        <h2 class="text-3xl font-semibold">Engineered Surface Protocols</h2>
        <p class="mt-4 max-w-3xl text-muted leading-relaxed">
          Three asset classes. Three execution tiers. Fixed, transparent protocol pricing.
        </p>

        <div class="mt-12">
          <ServiceMatrix />
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <section id="gallery" class="py-24 border-t border-border">
      <div class="mx-auto max-w-content px-4 sm:px-6">
        <h2 class="text-3xl font-semibold">Recent Work</h2>
        <p class="mt-4 max-w-3xl text-muted leading-relaxed">
          Condition-based execution. Documentation-first. Real results.
        </p>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

          <div class="border border-border overflow-hidden">
            <img
              src="/work/bmw-front.jpg"
              alt="Exterior front — documented finish"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>

          <div class="border border-border overflow-hidden">
            <img
              src="/work/bmw-wheel.jpg"
              alt="Wheels — brake dust reset"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>

          <div class="border border-border overflow-hidden">
            <img
              src="/work/bmw-interior.jpg"
              alt="Interior — reset pass"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>

          <div class="border border-border overflow-hidden">
            <img
              src="/work/cayenne-ambient.jpg"
              alt="Interior ambient detail"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>

          <div class="border border-border overflow-hidden">
            <img
              src="/work/roof-contamination.jpg"
              alt="Roof contamination assessment"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>

          <div class="border border-border overflow-hidden">
            <img
              src="/work/bmw-headlight.jpg"
              alt="Headlight reset"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </div>

        </div>
      </div>
    </section>

    <!-- REQUEST (INTAKE FORM) -->
    <section class="py-24 border-t border-border">
      <div class="mx-auto max-w-content px-4 sm:px-6">
        <RequestIntake />
      </div>
    </section>

  </main>
</BaseLayout>
