---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Planck Service Router">
  <main class="min-h-[calc(100vh-220px)] flex items-center">
    <div class="mx-auto w-full max-w-content px-4 sm:px-6">
      <section class="mx-auto max-w-4xl text-center">
        <p class="text-xs tracking-[0.22em] text-text/60 uppercase">
          service routing infrastructure
        </p>

        <h1 class="mt-6 text-6xl sm:text-7xl lg:text-8xl font-semibold tracking-tightest leading-none">
          planck
        </h1>

        <div class="mt-10 mx-auto max-w-3xl border border-border bg-bg/60 p-3 sm:p-4">
          <div class="relative" data-router-search>
            <div class="flex flex-col sm:flex-row gap-3">
              <input
                type="text"
                value=""
                placeholder="Search surface, region, or operator"
                class="w-full border border-border bg-transparent px-5 py-5 text-lg text-text outline-none placeholder:text-text/40"
                autocomplete="off"
                spellcheck="false"
                aria-label="Search surface, region, or operator"
                data-search-input
              />

              <button
                type="button"
                class="inline-flex items-center justify-center border border-border px-8 py-5 text-sm hover:border-accent transition-colors"
                data-search-button
              >
                Search
              </button>
            </div>

            <div
              class="absolute left-0 right-0 top-full z-20 mt-3 hidden border border-border bg-bg/95 text-left shadow-lg shadow-black/10 backdrop-blur"
              data-search-dropdown
            >
              <button
                type="button"
                class="block w-full border-b border-border px-4 py-4 text-left hover:bg-white/5 transition-colors"
                data-route="/surfaces/auto-detailing"
              >
                <span class="block text-sm text-text">auto detailing</span>
                <span class="mt-1 block text-xs text-muted">surface</span>
              </button>

              <button
                type="button"
                class="block w-full border-b border-border px-4 py-4 text-left hover:bg-white/5 transition-colors"
                data-route="/us/fl/miami/auto-detailing"
              >
                <span class="block text-sm text-text">miami</span>
                <span class="mt-1 block text-xs text-muted">regional route</span>
              </button>

              <button
                type="button"
                class="block w-full border-b border-border px-4 py-4 text-left hover:bg-white/5 transition-colors"
                data-route="/operators/qtm-detailing"
              >
                <span class="block text-sm text-text">qtm detailing</span>
                <span class="mt-1 block text-xs text-muted">operator</span>
              </button>

              <button
                type="button"
                class="block w-full px-4 py-4 text-left hover:bg-white/5 transition-colors"
                data-route="/operators/qtm-astrology"
              >
                <span class="block text-sm text-text">qtm astrology</span>
                <span class="mt-1 block text-xs text-muted">operator</span>
              </button>
            </div>
          </div>

          <p class="mt-3 text-xs text-muted">
            try: auto detailing · miami · qtm detailing · qtm astrology
          </p>
        </div>

        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-3 text-sm text-muted">
          <a href="/operators" class="hover:text-text transition-colors">
            Operators
          </a>

          <span class="text-border">·</span>

          <a href="/surfaces/auto-detailing" class="hover:text-text transition-colors">
            Auto Detailing
          </a>

          <span class="text-border">·</span>

          <a href="/us/fl/miami/auto-detailing" class="hover:text-text transition-colors">
            Miami
          </a>
        </div>
      </section>
    </div>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-router-search]");
      if (!root) return;

      const input = root.querySelector("[data-search-input]");
      const button = root.querySelector("[data-search-button]");
      const dropdown = root.querySelector("[data-search-dropdown]");
      const items = Array.from(root.querySelectorAll("[data-route]"));

      if (!(input instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement) || !(dropdown instanceof HTMLDivElement)) {
        return;
      }

      const routes = [
        {
          terms: ["auto detailing", "detailing", "auto"],
          route: "/surfaces/auto-detailing",
        },
        {
          terms: ["miami", "miami auto detailing"],
          route: "/us/fl/miami/auto-detailing",
        },
        {
          terms: ["qtm detailing", "qtm", "operator"],
          route: "/operators/qtm-detailing",
        },
        {
          terms: ["qtm astrology", "astrology"],
          route: "/operators/qtm-astrology",
        },
      ];

      let activeIndex = -1;
      let visibleItems = [];

      const normalize = (value) =>
        value
          .toLowerCase()
          .trim()
          .replace(/\s+/g, " ");

      const showDropdown = () => {
        dropdown.classList.remove("hidden");
      };

      const hideDropdown = () => {
        dropdown.classList.add("hidden");
        activeIndex = -1;
      };

      const updateVisibleItems = () => {
        visibleItems = items.filter((item) => !item.classList.contains("hidden"));
      };

      const renderActive = () => {
        visibleItems.forEach((item, index) => {
          if (index === activeIndex) {
            item.classList.add("bg-white/5");
          } else {
            item.classList.remove("bg-white/5");
          }
        });
      };

      const filterSuggestions = () => {
        const query = normalize(input.value);

        items.forEach((item) => {
          const label = normalize(item.textContent || "");
          const isMatch = !query || label.includes(query);
          item.classList.toggle("hidden", !isMatch);
        });

        updateVisibleItems();

        if (visibleItems.length > 0) {
          showDropdown();
        } else {
          hideDropdown();
        }

        activeIndex = -1;
        renderActive();
      };

      const resolveRoute = (value) => {
        const query = normalize(value);
        if (!query) return null;

        for (const entry of routes) {
          if (entry.terms.includes(query)) {
            return entry.route;
          }
        }

        for (const entry of routes) {
          if (entry.terms.some((term) => term.includes(query) || query.includes(term))) {
            return entry.route;
          }
        }

        return null;
      };

      const goToRoute = (value) => {
        const route = resolveRoute(value);
        if (route) {
          window.location.href = route;
        }
      };

      input.addEventListener("focus", () => {
        filterSuggestions();
      });

      input.addEventListener("input", () => {
        filterSuggestions();
      });

      input.addEventListener("keydown", (event) => {
        updateVisibleItems();

        if (event.key === "ArrowDown") {
          if (visibleItems.length === 0) return;
          event.preventDefault();
          showDropdown();
          activeIndex = (activeIndex + 1) % visibleItems.length;
          renderActive();
          return;
        }

        if (event.key === "ArrowUp") {
          if (visibleItems.length === 0) return;
          event.preventDefault();
          showDropdown();
          activeIndex = activeIndex <= 0 ? visibleItems.length - 1 : activeIndex - 1;
          renderActive();
          return;
        }

        if (event.key === "Enter") {
          event.preventDefault();

          if (activeIndex >= 0 && visibleItems[activeIndex]) {
            const route = visibleItems[activeIndex].getAttribute("data-route");
            if (route) {
              window.location.href = route;
              return;
            }
          }

          goToRoute(input.value);
          return;
        }

        if (event.key === "Escape") {
          hideDropdown();
        }
      });

      button.addEventListener("click", () => {
        goToRoute(input.value);
      });

      items.forEach((item) => {
        item.addEventListener("click", () => {
          const route = item.getAttribute("data-route");
          if (route) {
            window.location.href = route;
          }
        });
      });

      document.addEventListener("click", (event) => {
        if (!root.contains(event.target)) {
          hideDropdown();
        }
      });
    })();
  </script>
</BaseLayout>
