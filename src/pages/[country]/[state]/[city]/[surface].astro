---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { surfaces, getSurfaceBySlug } from "../../../../data/surfaces";
import { operators } from "../../../../data/operators";

export function getStaticPaths() {
  const seen = new Set<string>();

  return operators
    .filter((op) => op.country && op.state && op.city && op.surface)
    .filter((op) => {
      const key = `${op.country}/${op.state}/${op.city}/${op.surface}`;
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    })
    .map((op) => ({
      params: {
        country: op.country,
        state: op.state,
        city: op.city,
        surface: op.surface,
      },
    }));
}

const { country, state, city, surface } = Astro.params;

const surfaceData = getSurfaceBySlug(surface ?? "");

if (!surfaceData) {
  throw new Error(`Surface not found: ${surface}`);
}

const filteredOperators = operators.filter(
  (operator) =>
    operator.country === country &&
    operator.state === state &&
    operator.city === city &&
    operator.surface === surface
);
---

<BaseLayout title={`${surfaceData.name} in ${city}`}>
  <main class="py-24">
    <div class="mx-auto max-w-content px-6">

      <header class="max-w-3xl">
        <p class="text-xs tracking-wide text-text/70">
          planck surface
        </p>

        <h1 class="mt-4 text-4xl sm:text-5xl font-semibold tracking-tightest leading-tight">
          {surfaceData.name} · {city}
        </h1>

        <p class="mt-6 text-muted">
          Independent operators delivering structured service protocols.
        </p>
      </header>

      <section class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {filteredOperators.map((operator) => (
          <a
            href={`/operators/${operator.slug}`}
            class="block border border-border p-6 hover:border-accent transition-colors"
          >
            <div class="flex items-center gap-4">
              <img
                src={operator.logo}
                alt={operator.name}
                class="h-10 w-auto"
              />

              <div>
                <p class="text-lg font-medium text-text">
                  {operator.name}
                </p>

                <p class="text-sm text-text/70">
                  {operator.regionName}
                </p>
              </div>
            </div>

            <p class="mt-4 text-sm text-muted">
              {operator.tagline}
            </p>

            <p class="mt-6 text-sm text-accent">
              view operator →
            </p>
          </a>
        ))}
      </section>

    </div>
  </main>
</BaseLayout>
