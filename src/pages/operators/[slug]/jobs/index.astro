---
import { operators, getOperatorBySlug } from "../../../../data/operators";

export function getStaticPaths() {
  return operators.map((op) => ({ params: { slug: op.slug } }));
}

const { slug } = Astro.params;

const operator = getOperatorBySlug(slug ?? "");
if (!operator) {
  throw new Error(`Operator not found: ${slug}`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{operator.name} — Job</title>
  </head>
  <body class="bg-white text-black">
    <main class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
      <header class="mb-8">
        <a
          href={`/operators/${operator.slug}/dashboard`}
          class="text-xs text-black/40 hover:text-black/70 transition-colors"
        >
          ← Dashboard
        </a>
        <h1 class="mt-3 text-3xl font-semibold">{operator.name}</h1>
        <p class="mt-1 text-sm text-black/50">
          {operator.regionName}
        </p>
        <p class="mt-1 text-xs text-black/30 font-mono" id="job-id-display"></p>

        <!-- Lifecycle Rail -->
        <div class="mt-5 rounded-2xl border border-black/10 p-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-3">Job Lifecycle</p>
          <div id="lifecycle-rail" class="flex items-start gap-0 overflow-x-auto pb-1">
            <!-- rendered by JS after SE status is known -->
          </div>
          <p id="lifecycle-next-label" class="mt-3 text-xs text-black/40"></p>
        </div>
      </header>

      <section class="grid gap-6">
        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Tech Access</h2>
          <p class="mt-2 text-sm text-black/70">
            Single-tech mode. Enter the TECH token to load protected job data.
          </p>

          <div class="mt-4 flex flex-col gap-3 sm:flex-row">
            <input
              id="tech-token"
              type="password"
              placeholder="Enter TECH token"
              class="w-full rounded-xl border border-black/20 px-4 py-2 text-sm"
            />
            <button
              id="save-tech-token-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
            >
              Save Token
            </button>
          </div>

          <p id="tech-token-status" class="mt-3 text-sm text-black/60"></p>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Job Summary</h2>
          <div id="job-summary" class="mt-4 text-sm text-black/70">
            Waiting for token...
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Service Status</h2>
          <div id="event-summary" class="mt-4 text-sm text-black/70">
            Waiting for job load...
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <button
              id="load-job-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
            >
              Load Job
            </button>

            <button
              id="start-service-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
              disabled
            >
              Start Service
            </button>

            <button
              id="complete-service-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
              disabled
            >
              Complete Service
            </button>
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Arrival Photo</h2>
          <p id="arrival-evidence-count" class="mt-2 text-sm text-black/70">Load a job to enable photo capture.</p>
          <div id="arrival-thumbs" class="mt-3 flex flex-wrap gap-2"></div>
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <input id="arrival-file-input" type="file" accept="image/*" class="hidden" />
            <button
              id="arrival-capture-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
              disabled
            >
              Add Arrival Photo
            </button>
            <span id="arrival-upload-status" class="text-sm text-black/60"></span>
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Before Photos</h2>
          <p id="before-evidence-count" class="mt-2 text-sm text-black/70">Load a job to enable photo capture.</p>
          <div id="before-thumbs" class="mt-3 flex flex-wrap gap-2"></div>
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <input id="before-file-input" type="file" accept="image/*" class="hidden" />
            <button
              id="before-capture-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
              disabled
            >
              Add Before Photo
            </button>
            <span id="before-upload-status" class="text-sm text-black/60"></span>
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">After Photos</h2>
          <p id="after-evidence-count" class="mt-2 text-sm text-black/70">Load a job to enable photo capture.</p>
          <div id="after-thumbs" class="mt-3 flex flex-wrap gap-2"></div>
          <div class="mt-3 flex flex-wrap items-center gap-3">
            <input id="after-file-input" type="file" accept="image/*" class="hidden" />
            <button
              id="after-capture-btn"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
              disabled
            >
              Add After Photo
            </button>
            <span id="after-upload-status" class="text-sm text-black/60"></span>
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Payment</h2>
          <p id="payment-summary" class="mt-2 text-sm text-black/70">Load a job to record payment.</p>
          <div class="mt-4 grid gap-4">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="pay-status" class="block text-sm font-medium text-black/80">Status</label>
                <select
                  id="pay-status"
                  class="mt-2 w-full rounded-xl border border-black/20 px-4 py-3 text-sm"
                  disabled
                >
                  <option value="unpaid">unpaid</option>
                  <option value="partial">partial</option>
                  <option value="paid">paid</option>
                  <option value="waived">waived</option>
                </select>
              </div>
              <div>
                <label for="pay-amount" class="block text-sm font-medium text-black/80">Amount Collected</label>
                <input
                  id="pay-amount"
                  type="number"
                  min="0"
                  step="0.01"
                  inputmode="decimal"
                  class="mt-2 w-full rounded-xl border border-black/20 px-4 py-3 text-sm"
                  placeholder="0.00"
                  disabled
                />
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="pay-method" class="block text-sm font-medium text-black/80">Method</label>
                <select
                  id="pay-method"
                  class="mt-2 w-full rounded-xl border border-black/20 px-4 py-3 text-sm"
                  disabled
                >
                  <option value="">— select —</option>
                  <option value="cash">cash</option>
                  <option value="zelle">zelle</option>
                  <option value="venmo">venmo</option>
                  <option value="cash_app">cash app</option>
                  <option value="card">card</option>
                  <option value="other">other</option>
                </select>
              </div>
              <div>
                <label for="pay-note" class="block text-sm font-medium text-black/80">Note (optional)</label>
                <input
                  id="pay-note"
                  type="text"
                  class="mt-2 w-full rounded-xl border border-black/20 px-4 py-3 text-sm"
                  placeholder="e.g. Zelle sent at 12:30pm"
                  disabled
                />
              </div>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              <button
                id="save-payment-btn"
                type="button"
                class="rounded-xl border border-black px-4 py-2 text-sm"
                disabled
              >
                Save Payment
              </button>
              <span id="payment-status-msg" class="text-sm text-black/60"></span>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Completion</h2>

          <div class="mt-4 grid gap-4">
            <div>
              <label for="completion-summary" class="block text-sm font-medium text-black/80">
                Completion Summary
              </label>
              <textarea
                id="completion-summary"
                rows="4"
                class="mt-2 w-full rounded-xl border border-black/20 px-4 py-3 text-sm"
                placeholder="Summarize what was completed..."
              ></textarea>
            </div>
          </div>
        </div>
        <div class="rounded-2xl border border-black/10 p-5">
          <h2 class="text-lg font-medium">Service Report</h2>
          <div id="service-report" class="mt-4 text-sm text-black/70">
            Load a job to generate a report.
          </div>
        </div>
      </section>
    </main>

    <script
      define:vars={{
        operatorSlug: operator.slug,
        operatorSurface: operator.surface,
        operatorRegion: operator.regionName,
      }}
    >
      // Read jobId from URL query param: /operators/[slug]/jobs/?job=JOB_abc123
      const jobId = new URLSearchParams(window.location.search).get("job") ?? "";

      const jobIdDisplay = document.getElementById("job-id-display");
      if (jobIdDisplay && jobId) {
        jobIdDisplay.textContent = jobId;
      }

      const isEvent = operatorSurface === "event-coordination";

      // ── Surface-specific label overrides ─────────────────────────────────────
      if (isEvent) {
        // Button labels
        const btnMap = {
          "start-service-btn":    "Start Setup",
          "complete-service-btn": "Close Event",
          "load-job-btn":         "Load Event",
        };
        for (const [id, label] of Object.entries(btnMap)) {
          const el = document.getElementById(id);
          if (el) el.textContent = label;
        }

        // Tech Access section
        const techInput = document.getElementById("tech-token");
        if (techInput) {
          const sec = techInput.closest(".rounded-2xl");
          if (sec) {
            const h2 = sec.querySelector("h2");
            if (h2) h2.textContent = "Operator Access";
            const desc = sec.querySelector("p.mt-2");
            if (desc) desc.textContent = "Enter the operator access token to load event data.";
          }
          techInput.placeholder = "Enter operator token";
        }

        // Job Summary → Event Details
        const jobSumSec = document.getElementById("job-summary")?.closest(".rounded-2xl");
        if (jobSumSec) { const h2 = jobSumSec.querySelector("h2"); if (h2) h2.textContent = "Event Details"; }

        // Service Status → Event Status
        const evtSumSec = document.getElementById("event-summary")?.closest(".rounded-2xl");
        if (evtSumSec) { const h2 = evtSumSec.querySelector("h2"); if (h2) h2.textContent = "Event Status"; }

        // Payment → Settlement
        const paySec = document.getElementById("pay-status")?.closest(".rounded-2xl");
        if (paySec) { const h2 = paySec.querySelector("h2"); if (h2) h2.textContent = "Settlement"; }

        // Completion → Event Closeout; label → Event Summary
        const completionSec = document.getElementById("completion-summary")?.closest(".rounded-2xl");
        if (completionSec) {
          const h2 = completionSec.querySelector("h2");
          if (h2) h2.textContent = "Event Closeout";
          const lbl = completionSec.querySelector("label .block, label span.block");
          if (lbl) lbl.textContent = "Event Summary";
        }
        const completionTextarea = document.getElementById("completion-summary");
        if (completionTextarea) completionTextarea.placeholder = "Summarize the event execution, outcomes, and any notable items.";

        // Service Report → Event Record
        const reportSec = document.getElementById("service-report")?.closest(".rounded-2xl");
        if (reportSec) { const h2 = reportSec.querySelector("h2"); if (h2) h2.textContent = "Event Record"; }

        // Lifecycle rail header
        const railWrap = document.getElementById("lifecycle-rail")?.closest(".rounded-2xl");
        if (railWrap) { const p = railWrap.querySelector("p"); if (p) p.textContent = "Event Lifecycle"; }

        // Photo section headings and add-photo buttons
        const arrivalCapBtn = document.getElementById("arrival-capture-btn");
        if (arrivalCapBtn) {
          const sec = arrivalCapBtn.closest(".rounded-2xl");
          const h2 = sec && sec.querySelector("h2");
          if (h2) h2.textContent = "Vendor Arrival Photo";
          arrivalCapBtn.textContent = "Add Vendor Arrival Photo";
        }
        const beforeCapBtn = document.getElementById("before-capture-btn");
        if (beforeCapBtn) {
          const sec = beforeCapBtn.closest(".rounded-2xl");
          const h2 = sec && sec.querySelector("h2");
          if (h2) h2.textContent = "Setup Photos";
          beforeCapBtn.textContent = "Add Setup Photo";
        }
        const afterCapBtn = document.getElementById("after-capture-btn");
        if (afterCapBtn) {
          const sec = afterCapBtn.closest(".rounded-2xl");
          const h2 = sec && sec.querySelector("h2");
          if (h2) h2.textContent = "Post-Event Photos";
          afterCapBtn.textContent = "Add Post-Event Photo";
        }
      }

      const TECH_TOKEN_KEY = "planck.tech_token";

      const techTokenInput = document.getElementById("tech-token");
      const saveTechTokenBtn = document.getElementById("save-tech-token-btn");
      const techTokenStatusEl = document.getElementById("tech-token-status");

      const jobSummaryEl = document.getElementById("job-summary");
      const eventSummaryEl = document.getElementById("event-summary");
      const loadJobBtn = document.getElementById("load-job-btn");
      const startBtn = document.getElementById("start-service-btn");
      const completeBtn = document.getElementById("complete-service-btn");

      const completionSummaryInput = document.getElementById("completion-summary");

      const payStatusInput = document.getElementById("pay-status");
      const payAmountInput = document.getElementById("pay-amount");
      const payMethodInput = document.getElementById("pay-method");
      const payNoteInput = document.getElementById("pay-note");
      const savePaymentBtn = document.getElementById("save-payment-btn");
      const paymentStatusMsg = document.getElementById("payment-status-msg");
      const paymentSummaryEl = document.getElementById("payment-summary");

      const beforeFileInput = document.getElementById("before-file-input");
      const beforeCaptureBtn = document.getElementById("before-capture-btn");
      const beforeEvidenceCount = document.getElementById("before-evidence-count");
      const beforeUploadStatus = document.getElementById("before-upload-status");

      const afterFileInput = document.getElementById("after-file-input");
      const afterCaptureBtn = document.getElementById("after-capture-btn");
      const afterEvidenceCount = document.getElementById("after-evidence-count");
      const afterUploadStatus = document.getElementById("after-upload-status");

      const arrivalFileInput = document.getElementById("arrival-file-input");
      const arrivalCaptureBtn = document.getElementById("arrival-capture-btn");
      const arrivalEvidenceCount = document.getElementById("arrival-evidence-count");
      const arrivalUploadStatus = document.getElementById("arrival-upload-status");

      let job = null;
      let serviceEvent = null;
      const localEvidence = { arrival: [], before: [], after: [] };

      // ── Lifecycle rail ────────────────────────────────────────────────────────

      const LIFECYCLE_STEPS = isEvent
        ? [
            { key: "queued",      label: "Queued"         },
            { key: "claimed",     label: "Confirmed"      },
            { key: "arrived",     label: "Vendor Arrival" },
            { key: "in_progress", label: "Event Live"     },
            { key: "evidence",    label: "Breakdown"      },
            { key: "complete",    label: "Closed"         },
          ]
        : [
            { key: "queued",      label: "Queued"      },
            { key: "claimed",     label: "Claimed"     },
            { key: "arrived",     label: "Arrived"     },
            { key: "in_progress", label: "In Progress" },
            { key: "evidence",    label: "Evidence"    },
            { key: "complete",    label: "Complete"    },
          ];

      const LIFECYCLE_NEXT_LABELS = isEvent ? {
        queued:      "Awaiting confirmation.",
        claimed:     "Load event and confirm vendor access.",
        arrived:     "Begin setup when vendors are ready.",
        in_progress: "Capture setup and in-progress photos.",
        evidence:    "Close event and record settlement.",
        complete:    "Event closed.",
      } : {
        queued:      "Waiting to be claimed.",
        claimed:     "Load job and mark arrival.",
        arrived:     "Start service when ready.",
        in_progress: "Capture before photos.",
        evidence:    "Complete service and record payment.",
        complete:    "Job complete.",
      };

      function resolveLifecycleStepFromSE(eventData) {
        if (!eventData) return "claimed";
        const status        = eventData.status;
        const payStatus     = eventData.meta?.payment_status ?? null;
        const evidenceCount =
          (eventData.evidence?.arrival?.length ?? 0) +
          (eventData.evidence?.before?.length ?? 0) +
          (eventData.evidence?.after?.length ?? 0) +
          localEvidence.arrival.length +
          localEvidence.before.length +
          localEvidence.after.length;

        if (status === "created")     return "arrived";
        if (status === "in_progress") return evidenceCount > 0 ? "evidence" : "in_progress";
        if (status === "completed")   return (payStatus === "paid" || payStatus === "waived") ? "complete" : "evidence";
        return "claimed";
      }

      function renderLifecycleRail(currentKey) {
        const rail      = document.getElementById("lifecycle-rail");
        const nextLabel = document.getElementById("lifecycle-next-label");
        if (!rail) return;

        const currentIdx = LIFECYCLE_STEPS.findIndex(s => s.key === currentKey);

        rail.innerHTML = LIFECYCLE_STEPS.map((step, idx) => {
          const isPast    = idx < currentIdx;
          const isCurrent = idx === currentIdx;

          const dotClass = isCurrent
            ? "h-2.5 w-2.5 rounded-full bg-black flex-shrink-0"
            : isPast
              ? "h-2 w-2 rounded-full bg-black/30 flex-shrink-0"
              : "h-2 w-2 rounded-full border border-black/20 flex-shrink-0";

          const labelClass = isCurrent
            ? "text-[11px] font-semibold text-black mt-1.5 whitespace-nowrap"
            : isPast
              ? "text-[11px] text-black/30 mt-1.5 whitespace-nowrap"
              : "text-[11px] text-black/20 mt-1.5 whitespace-nowrap";

          const connector = idx < LIFECYCLE_STEPS.length - 1
            ? `<div class="h-px flex-1 min-w-[8px] mt-[5px] self-start ${isPast || isCurrent ? "bg-black/20" : "bg-black/08"}"></div>`
            : "";

          return `<div class="flex flex-col items-center min-w-0"><div class="${dotClass}"></div><span class="${labelClass}">${step.label}</span></div>${connector}`;
        }).join("");

        if (nextLabel) {
          nextLabel.textContent = LIFECYCLE_NEXT_LABELS[currentKey] ?? "";
        }
      }

      // ── Helpers ───────────────────────────────────────────────────────────────

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function getTechToken() {
        try {
          return sessionStorage.getItem(TECH_TOKEN_KEY) || "";
        } catch {
          return "";
        }
      }

      function setTechToken(value) {
        try {
          sessionStorage.setItem(TECH_TOKEN_KEY, value);
        } catch {}
      }

      function renderTechTokenStatus() {
        const token = getTechToken();
        if (!techTokenStatusEl) return;

        techTokenStatusEl.textContent = token
          ? (isEvent ? "Operator token stored for this session." : "TECH token stored for this browser session.")
          : (isEvent ? "No operator token stored yet." : "No TECH token stored yet.");
      }

      function renderJob(jobData) {
        if (!jobSummaryEl) return;

        if (!jobData) {
          jobSummaryEl.innerHTML = isEvent ? "<p>Enter access token to load event.</p>" : "<p>Job not loaded.</p>";
          return;
        }

        const packet = jobData.packet || {};
        const state = jobData.state || {};
        const data = packet.intake_snapshot?.data || {};
        const contact = data.contact || {};
        const asset = data.asset || {};
        const request = data.request || {};
        const notes = data.notes || {};

        jobSummaryEl.innerHTML = `
          <div class="grid gap-2">
            <p><strong>${isEvent ? "Event Status" : "Job Status"}:</strong> ${escapeHtml(state.status || "unknown")}</p>
            <p><strong>${isEvent ? "Confirmed At" : "Claimed At"}:</strong> ${escapeHtml(state.claimed_at || "")}</p>
            <p><strong>Customer:</strong> ${escapeHtml(contact.name || "unknown")}</p>
            <p><strong>Email:</strong> ${escapeHtml(contact.email || "")}</p>
            <p><strong>Phone:</strong> ${escapeHtml(contact.phone || "")}</p>
            <p><strong>Asset Class:</strong> ${escapeHtml(asset.class || "")}</p>
            <p><strong>Asset Details:</strong> ${escapeHtml(asset.details || "")}</p>
            <p><strong>Tier:</strong> ${escapeHtml(request.tier_id || request.tier || "")}</p>
            <p><strong>Service Area:</strong> ${escapeHtml(request.service_area || "")}</p>
            <p><strong>Condition Notes:</strong> ${escapeHtml(notes.condition || "")}</p>
          </div>
        `;
      }

      function renderServiceEvent(eventData) {
        if (!eventSummaryEl || !startBtn || !completeBtn) return;

        // Keep lifecycle rail in sync with current SE status
        renderLifecycleRail(resolveLifecycleStepFromSE(eventData));

        if (!eventData) {
          eventSummaryEl.innerHTML = isEvent ? "<p>Load an event to begin.</p>" : "<p>No ServiceEvent loaded.</p>";
          startBtn.disabled = true;
          completeBtn.disabled = true;
          return;
        }

        eventSummaryEl.innerHTML = `
          <div class="grid gap-2">
            <p><strong>ServiceEvent ID:</strong> ${escapeHtml(eventData.id)}</p>
            <p><strong>Status:</strong> ${escapeHtml(eventData.status)}</p>
            <p><strong>Created:</strong> ${escapeHtml(eventData.timestamps?.created_at || "")}</p>
            <p><strong>Started:</strong> ${escapeHtml(eventData.timestamps?.started_at || "")}</p>
            <p><strong>Completed:</strong> ${escapeHtml(eventData.timestamps?.completed_at || "")}</p>
            <p><strong>${isEvent ? "Event Summary" : "Completion Summary"}:</strong> ${escapeHtml(
              eventData.outcome?.completion_summary || ""
            )}</p>
          </div>
        `;

        if (completionSummaryInput) {
          completionSummaryInput.value = eventData.outcome?.completion_summary || "";
        }

        renderPayment(eventData);

        startBtn.disabled = eventData.status !== "created";
        completeBtn.disabled = eventData.status !== "in_progress";
        renderReport();
      }

      function renderPayment(eventData) {
        const meta = eventData?.meta || {};
        if (payStatusInput) payStatusInput.value = meta.payment_status || "unpaid";
        if (payAmountInput) {
          payAmountInput.value = typeof meta.amount_collected === "number"
            ? String(meta.amount_collected)
            : "";
        }
        if (payMethodInput) payMethodInput.value = meta.payment_method || "";
        if (payNoteInput) payNoteInput.value = meta.payment_note || "";
        if (paymentSummaryEl) {
          const status = meta.payment_status || "unpaid";
          const amount = typeof meta.amount_collected === "number"
            ? `$${meta.amount_collected}`
            : "—";
          const method = meta.payment_method || "—";
          paymentSummaryEl.textContent = `${status} · ${amount} · ${method}`;
        }
      }

      function renderReport() {
        // Refresh lifecycle rail — evidence counts may have changed
        if (serviceEvent) renderLifecycleRail(resolveLifecycleStepFromSE(serviceEvent));

        const reportEl = document.getElementById("service-report");
        if (!reportEl) return;

        if (!job || !serviceEvent) {
          reportEl.innerHTML = isEvent ? "<p>Load an event to generate a record.</p>" : "<p>Load a job to generate a report.</p>";
          return;
        }

        const snap = job.packet?.intake_snapshot?.data || {};
        const contact = snap.contact || {};
        const asset = snap.asset || {};
        const request = snap.request || {};

        const ts = serviceEvent.timestamps || {};
        const outcome = serviceEvent.outcome || {};
        const evidence = serviceEvent.evidence || {};
        const meta = serviceEvent.meta || {};

        const arrivalCount = Array.isArray(evidence.arrival) ? evidence.arrival.length : 0;
        const beforeCount = Array.isArray(evidence.before) ? evidence.before.length : 0;
        const afterCount = Array.isArray(evidence.after) ? evidence.after.length : 0;
        const localArrivalCount = localEvidence.arrival.length;
        const localBeforeCount = localEvidence.before.length;
        const localAfterCount = localEvidence.after.length;

        function row(label, value) {
          if (value === null || value === undefined || value === "") return "";
          return `<div class="flex gap-2 py-0.5">
            <span class="w-36 shrink-0 text-black/40">${escapeHtml(label)}</span>
            <span class="text-black/80">${escapeHtml(String(value))}</span>
          </div>`;
        }

        function section(title, rows) {
          const content = rows.filter(Boolean).join("");
          if (!content) return "";
          return `<div>
            <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-black/30">${escapeHtml(title)}</p>
            <div class="grid">${content}</div>
          </div>`;
        }

        const amountDisplay = typeof meta.amount_collected === "number"
          ? `$${meta.amount_collected}`
          : "";

        // Evidence counts: take max of persisted (from serviceEvent) and local in-memory
        const effectiveArrival = Math.max(arrivalCount, localArrivalCount);
        const effectiveBefore = Math.max(beforeCount, localBeforeCount);
        const effectiveAfter = Math.max(afterCount, localAfterCount);

        reportEl.innerHTML = `<div class="grid gap-5">
          ${section("Customer", [
            row("Name", contact.name),
          ])}
          ${section("Asset", [
            row("Class", asset.class),
            row("Details", asset.details),
          ])}
          ${section(isEvent ? "Coordination" : "Service", [
            row("Tier", request.tier_id || request.tier),
            row("Area", request.service_area),
          ])}
          ${section("Execution", [
            row("Created", ts.created_at),
            row("Started", ts.started_at),
            row("Completed", ts.completed_at),
            row("Summary", outcome.completion_summary),
          ])}
          ${section("Evidence", [
            row(isEvent ? "Vendor arrival photo" : "Arrival photo", String(effectiveArrival)),
            row(isEvent ? "Setup photos"         : "Before photos",  String(effectiveBefore)),
            row(isEvent ? "Post-event photos"    : "After photos",   String(effectiveAfter)),
          ])}
          ${section(isEvent ? "Settlement" : "Payment", [
            row("Status", meta.payment_status),
            row("Amount collected", amountDisplay),
            row("Method", meta.payment_method),
            row("Note", meta.payment_note),
          ])}
        </div>`;
      }

      async function renderThumbnails(stage) {
        const containerId = stage === "arrival" ? "arrival-thumbs" : stage === "before" ? "before-thumbs" : "after-thumbs";
        const container = document.getElementById(containerId);
        if (!container) return;

        // Merge persisted evidence keys with local session keys; dedup by key
        const allKeys = new Set([
          ...(serviceEvent?.evidence?.[stage] || []).map(i => i.key).filter(Boolean),
          ...(localEvidence[stage] || []).map(i => i.key).filter(Boolean),
        ]);

        if (allKeys.size === 0) {
          container.innerHTML = "";
          return;
        }

        // Revoke existing blob URLs before clearing
        container.querySelectorAll("img[data-blob]").forEach(img => {
          URL.revokeObjectURL(img.src);
        });
        container.innerHTML = "";

        const token = getTechToken();
        for (const key of allKeys) {
          try {
            const res = await fetch(`/api/evidence?key=${encodeURIComponent(key)}`, {
              headers: { "x-tech-token": token },
            });
            if (!res.ok) continue;
            const blob = await res.blob();
            const blobUrl = URL.createObjectURL(blob);
            const img = document.createElement("img");
            img.src = blobUrl;
            img.dataset.blob = "1";
            img.alt = stage === "arrival" ? "Arrival" : stage === "before" ? "Before" : "After";
            img.className = "h-24 w-24 rounded-xl object-cover border border-black/10";
            container.appendChild(img);
          } catch {
            // skip — don't block other thumbnails
          }
        }
      }

      function renderEvidence(stage) {
        const countEl = stage === "arrival" ? arrivalEvidenceCount : stage === "before" ? beforeEvidenceCount : afterEvidenceCount;
        if (!countEl) return;
        const count = localEvidence[stage].length;
        countEl.textContent = count === 0
          ? "No photos uploaded yet."
          : `${count} photo${count === 1 ? "" : "s"} uploaded.`;
      }

      async function uploadPhoto(file, stage) {
        if (!file.type.startsWith("image/")) {
          throw new Error("invalid_file_type — select an image file");
        }

        // Map stage to the category enum accepted by /api/upload-url
        const category = stage === "after" ? "interior" : "exterior";
        const rawExt = (file.name.split(".").pop() || "jpg").toLowerCase().replace(/[^a-z0-9]/g, "");
        const safeName = `${stage}_${Date.now()}.${rawExt || "jpg"}`;

        // 1. Request upload URL
        const urlRes = await fetch("/api/upload-url", {
          method: "POST",
          headers: { "content-type": "application/json; charset=utf-8" },
          body: JSON.stringify({
            intake_id: jobId,
            category,
            filename: safeName,
            mime: file.type,
            bytes: file.size,
          }),
        });
        const urlData = await urlRes.json().catch(() => null);
        if (!urlRes.ok || !urlData?.ok) {
          throw new Error(urlData?.error || `upload_url_failed_${urlRes.status}`);
        }

        // 2. Upload file body to R2
        const uploadRes = await fetch(urlData.uploadUrl, {
          method: "PUT",
          body: file,
          headers: { "content-type": file.type },
        });
        if (!uploadRes.ok) {
          throw new Error(`upload_failed_${uploadRes.status}`);
        }

        // 3. Record evidence item (in-memory only — no /api/service-events/update exists)
        const item = {
          key: urlData.key,
          kind: "photo",
          caption: "",
          created_at: new Date().toISOString(),
        };
        localEvidence[stage].push(item);
        return item;
      }

      async function loadJob() {
        const token = getTechToken();
        if (!token) {
          throw new Error("missing_tech_token");
        }

        const res = await fetch(`/api/job/by_id/${encodeURIComponent(jobId)}`, {
          method: "GET",
          headers: {
            accept: "application/json",
            "x-tech-token": token,
            "x-operator-slug": operatorSlug,
          },
        });

        const data = await res.json().catch(() => null);

        if (!res.ok || !data?.ok || !data?.job) {
          throw new Error(data?.error || `job_load_failed_${res.status}`);
        }

        if (data.job.state?.assigned_to !== operatorSlug) {
          throw new Error("Not assigned to you — return to dashboard.");
        }

        const jobStatus = String(data.job.state?.status || "").toLowerCase();
        if (jobStatus !== "active") {
          throw new Error(`Job not claimed — status is "${jobStatus}". Claim the job from the dashboard before executing.`);
        }

        return data.job;
      }

      function buildCreatePayload(jobData) {
        const packet = jobData.packet || {};
        const packetData = packet.intake_snapshot?.data || packet.data || {};
        const request = packetData.request || {};
        const notes = packetData.notes || {};

        return {
          job_id: String(jobData.job_id || jobId),
          request_id: String(packet.id || `req_${jobId}`),
          operator_id: String(operatorSlug),
          customer_id: `cust_${String(jobData.job_id || jobId)}`,
          asset_id: `asset_${String(jobData.job_id || jobId)}`,
          location: {
            type: "onsite",
            address: String(request.service_area || operatorRegion || ""),
            geo: {
              lat: null,
              lng: null,
            },
          },
          service: {
            surface: String(operatorSurface || "auto-detailing"),
            tier: String(request.tier_id || request.tier || "unknown"),
            scope_notes: String(notes.scope || notes.condition || notes.description || ""),
          },
        };
      }

      async function createOrLoadServiceEvent(jobData) {
        const payload = buildCreatePayload(jobData);

        const res = await fetch("/api/service-events/create", {
          method: "POST",
          headers: {
            "content-type": "application/json; charset=utf-8",
            accept: "application/json",
          },
          body: JSON.stringify(payload),
        });

        const data = await res.json().catch(() => null);
        if (!res.ok || !data?.ok || !data?.service_event) {
          throw new Error(data?.error || `service_event_create_failed_${res.status}`);
        }

        return data.service_event;
      }

      async function startServiceEventById(serviceEventId) {
        const res = await fetch("/api/service-events/start", {
          method: "POST",
          headers: {
            "content-type": "application/json; charset=utf-8",
            accept: "application/json",
          },
          body: JSON.stringify({
            service_event_id: serviceEventId,
          }),
        });

        const data = await res.json().catch(() => null);
        if (!res.ok || !data?.ok || !data?.service_event) {
          throw new Error(data?.error || `service_event_start_failed_${res.status}`);
        }

        return data.service_event;
      }

      async function completeServiceEventById(serviceEventId) {
        const completion_summary = String(completionSummaryInput?.value || "").trim();

        const res = await fetch("/api/service-events/complete", {
          method: "POST",
          headers: {
            "content-type": "application/json; charset=utf-8",
            accept: "application/json",
          },
          body: JSON.stringify({
            service_event_id: serviceEventId,
            completion_summary,
          }),
        });

        const data = await res.json().catch(() => null);
        if (!res.ok || !data?.ok || !data?.service_event) {
          throw new Error(data?.error || `service_event_complete_failed_${res.status}`);
        }

        return data.service_event;
      }

      async function completeJob() {
        const token = getTechToken();
        const res = await fetch("/api/job/complete", {
          method: "POST",
          headers: {
            "content-type": "application/json; charset=utf-8",
            accept: "application/json",
            "x-tech-token": token,
            "x-operator-slug": operatorSlug,
          },
          body: JSON.stringify({}),
        });
        const data = await res.json().catch(() => null);
        if (!res.ok || !data?.ok) {
          throw new Error(data?.error || `job_complete_failed_${res.status}`);
        }
        return data.job;
      }

      async function routeAfterCompletion() {
        const token = getTechToken();
        const headers = {
          accept: "application/json",
          "x-tech-token": token,
          "x-operator-slug": operatorSlug,
        };

        const activeRes = await fetch("/api/job/active", { method: "GET", headers }).catch(() => null);
        const activeData = activeRes ? await activeRes.json().catch(() => null) : null;

        if (activeData?.ok && activeData?.job) {
          window.location.href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(activeData.job.job_id)}`;
          return;
        }

        const currentRes = await fetch("/api/job/current", { method: "GET", headers }).catch(() => null);
        const currentData = currentRes ? await currentRes.json().catch(() => null) : null;

        if (currentData?.ok && currentData?.job) {
          window.location.href = `/operators/${operatorSlug}/dashboard`;
          return;
        }

        window.location.href = `/operators/${operatorSlug}/dashboard`;
      }

      async function boot() {
        const existingToken = getTechToken();
        if (techTokenInput && existingToken) {
          techTokenInput.value = existingToken;
        }

        renderLifecycleRail("claimed");
        renderTechTokenStatus();
        renderJob(null);
        renderServiceEvent(null);

        // Auto-load if job ID is in URL and token is already stored.
        if (jobId && existingToken) {
          loadJobBtn?.click();
        }
      }

      saveTechTokenBtn?.addEventListener("click", () => {
        const value = String(techTokenInput?.value || "").trim();
        setTechToken(value);
        renderTechTokenStatus();
      });

      loadJobBtn?.addEventListener("click", async () => {
        if (jobSummaryEl) jobSummaryEl.innerHTML = isEvent ? "<p>Loading event context...</p>" : "<p>Loading job context...</p>";
        if (eventSummaryEl) eventSummaryEl.innerHTML = isEvent ? "<p>Initializing event record...</p>" : "<p>Initializing service event...</p>";
        startBtn.disabled = true;
        completeBtn.disabled = true;
        if (beforeCaptureBtn) beforeCaptureBtn.disabled = true;
        if (afterCaptureBtn) afterCaptureBtn.disabled = true;
        if (payStatusInput) payStatusInput.disabled = true;
        if (payAmountInput) payAmountInput.disabled = true;
        if (payMethodInput) payMethodInput.disabled = true;
        if (payNoteInput) payNoteInput.disabled = true;
        if (savePaymentBtn) savePaymentBtn.disabled = true;

        try {
          job = await loadJob();
          renderJob(job);

          serviceEvent = await createOrLoadServiceEvent(job);
          renderServiceEvent(serviceEvent);

          if (arrivalCaptureBtn) arrivalCaptureBtn.disabled = false;
          if (beforeCaptureBtn) beforeCaptureBtn.disabled = false;
          if (afterCaptureBtn) afterCaptureBtn.disabled = false;
          renderEvidence("arrival");
          renderEvidence("before");
          renderEvidence("after");
          renderThumbnails("arrival");
          renderThumbnails("before");
          renderThumbnails("after");

          if (payStatusInput) payStatusInput.disabled = false;
          if (payAmountInput) payAmountInput.disabled = false;
          if (payMethodInput) payMethodInput.disabled = false;
          if (payNoteInput) payNoteInput.disabled = false;
          if (savePaymentBtn) savePaymentBtn.disabled = false;
        } catch (err) {
          const message = err instanceof Error ? err.message : "unknown_error";
          if (jobSummaryEl) jobSummaryEl.innerHTML = `<p>Error: ${escapeHtml(message)}</p>`;
          if (eventSummaryEl) {
            eventSummaryEl.innerHTML = job
              ? `<p>${isEvent ? "Event record error" : "Service event error"}: ${escapeHtml(message)}</p>`
              : `<p>${isEvent ? "Event blocked — record not created." : "Job blocked — service event not created."}</p>`;
          }
        }
      });

      startBtn?.addEventListener("click", async () => {
        if (!serviceEvent?.id) return;

        startBtn.disabled = true;

        try {
          serviceEvent = await startServiceEventById(serviceEvent.id);
          renderServiceEvent(serviceEvent);
        } catch (err) {
          const message = err instanceof Error ? err.message : "unknown_error";
          if (eventSummaryEl) {
            eventSummaryEl.innerHTML += `<p class="mt-3">Start error: ${escapeHtml(message)}</p>`;
          }
          renderServiceEvent(serviceEvent);
        }
      });

      completeBtn?.addEventListener("click", async () => {
        if (!serviceEvent?.id) return;

        if (!confirm(isEvent ? "Close this event? This cannot be undone." : "Mark this job as complete? This cannot be undone.")) return;

        completeBtn.disabled = true;

        try {
          serviceEvent = await completeServiceEventById(serviceEvent.id);
          renderServiceEvent(serviceEvent);
        } catch (err) {
          const message = err instanceof Error ? err.message : "unknown_error";
          if (eventSummaryEl) {
            eventSummaryEl.innerHTML += `<p class="mt-3">Complete error: ${escapeHtml(message)}</p>`;
          }
          renderServiceEvent(serviceEvent);
          return;
        }

        try {
          await completeJob();
        } catch (err) {
          const message = err instanceof Error ? err.message : "unknown_error";
          if (eventSummaryEl) {
            eventSummaryEl.innerHTML += `<p class="mt-3">Job close error: ${escapeHtml(message)}</p>`;
          }
          completeBtn.disabled = false;
          return;
        }

        await routeAfterCompletion();
      });

      async function persistEvidence(serviceEventId, stage, item) {
        const res = await fetch("/api/service-events/add-evidence", {
          method: "POST",
          headers: {
            "content-type": "application/json; charset=utf-8",
            accept: "application/json",
          },
          body: JSON.stringify({
            service_event_id: serviceEventId,
            stage,
            items: [item],
          }),
        });
        const data = await res.json().catch(() => null);
        if (!res.ok || !data?.ok) {
          throw new Error(data?.error || `persist_evidence_failed_${res.status}`);
        }
        return data.service_event;
      }

      savePaymentBtn?.addEventListener("click", async () => {
        if (!serviceEvent?.id) return;
        if (savePaymentBtn) savePaymentBtn.disabled = true;
        if (paymentStatusMsg) paymentStatusMsg.textContent = "Saving…";

        const payment_status = payStatusInput?.value || "unpaid";
        const amount_raw = String(payAmountInput?.value || "").trim();
        const payment_method = payMethodInput?.value || "";
        const payment_note = String(payNoteInput?.value || "").trim();

        try {
          const res = await fetch("/api/service-events/update-payment", {
            method: "POST",
            headers: {
              "content-type": "application/json; charset=utf-8",
              accept: "application/json",
            },
            body: JSON.stringify({
              service_event_id: serviceEvent.id,
              payment_status,
              amount_collected: amount_raw === "" ? null : Number(amount_raw),
              payment_method: payment_method || undefined,
              payment_note: payment_note || undefined,
            }),
          });
          const data = await res.json().catch(() => null);
          if (!res.ok || !data?.ok) {
            throw new Error(data?.error || `update_payment_failed_${res.status}`);
          }
          serviceEvent = data.service_event;
          renderPayment(serviceEvent);
          renderReport();
          if (paymentStatusMsg) paymentStatusMsg.textContent = "Saved.";
        } catch (err) {
          const msg = err instanceof Error ? err.message : "save_error";
          if (paymentStatusMsg) paymentStatusMsg.textContent = `Error: ${escapeHtml(msg)}`;
        } finally {
          if (savePaymentBtn) savePaymentBtn.disabled = false;
        }
      });

      arrivalCaptureBtn?.addEventListener("click", () => arrivalFileInput?.click());
      beforeCaptureBtn?.addEventListener("click", () => beforeFileInput?.click());
      afterCaptureBtn?.addEventListener("click", () => afterFileInput?.click());

      beforeFileInput?.addEventListener("change", async () => {
        const file = beforeFileInput.files?.[0];
        if (!file || !job || !serviceEvent) return;
        beforeCaptureBtn.disabled = true;
        if (beforeUploadStatus) beforeUploadStatus.textContent = "Uploading…";
        let item;
        try {
          item = await uploadPhoto(file, "before");
          renderEvidence("before");
          if (beforeUploadStatus) beforeUploadStatus.textContent = "Saving…";
          serviceEvent = await persistEvidence(serviceEvent.id, "before", item);
          await renderThumbnails("before");
          if (beforeUploadStatus) beforeUploadStatus.textContent = "Saved.";
        } catch (err) {
          const msg = err instanceof Error ? err.message : "upload_error";
          if (beforeUploadStatus) beforeUploadStatus.textContent = `Error: ${escapeHtml(msg)}`;
        } finally {
          beforeCaptureBtn.disabled = false;
          beforeFileInput.value = "";
        }
      });

      afterFileInput?.addEventListener("change", async () => {
        const file = afterFileInput.files?.[0];
        if (!file || !job || !serviceEvent) return;
        afterCaptureBtn.disabled = true;
        if (afterUploadStatus) afterUploadStatus.textContent = "Uploading…";
        let item;
        try {
          item = await uploadPhoto(file, "after");
          renderEvidence("after");
          if (afterUploadStatus) afterUploadStatus.textContent = "Saving…";
          serviceEvent = await persistEvidence(serviceEvent.id, "after", item);
          await renderThumbnails("after");
          if (afterUploadStatus) afterUploadStatus.textContent = "Saved.";
        } catch (err) {
          const msg = err instanceof Error ? err.message : "upload_error";
          if (afterUploadStatus) afterUploadStatus.textContent = `Error: ${escapeHtml(msg)}`;
        } finally {
          afterCaptureBtn.disabled = false;
          afterFileInput.value = "";
        }
      });

      arrivalFileInput?.addEventListener("change", async () => {
        const file = arrivalFileInput.files?.[0];
        if (!file || !job || !serviceEvent) return;
        arrivalCaptureBtn.disabled = true;
        if (arrivalUploadStatus) arrivalUploadStatus.textContent = "Uploading…";
        let item;
        try {
          item = await uploadPhoto(file, "arrival");
          renderEvidence("arrival");
          if (arrivalUploadStatus) arrivalUploadStatus.textContent = "Saving…";
          serviceEvent = await persistEvidence(serviceEvent.id, "arrival", item);
          await renderThumbnails("arrival");
          if (arrivalUploadStatus) arrivalUploadStatus.textContent = "Saved.";
        } catch (err) {
          const msg = err instanceof Error ? err.message : "upload_error";
          if (arrivalUploadStatus) arrivalUploadStatus.textContent = `Error: ${escapeHtml(msg)}`;
        } finally {
          arrivalCaptureBtn.disabled = false;
          arrivalFileInput.value = "";
        }
      });

      boot();
    </script>
  </body>
</html>
