---
import { operators, getOperatorBySlug } from "../../../data/operators";

export function getStaticPaths() {
  return operators.map((op) => ({ params: { slug: op.slug } }));
}

const { slug } = Astro.params;
const operator = getOperatorBySlug(slug ?? "");
if (!operator) {
  throw new Error(`Operator not found: ${slug}`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{operator.name} — Dashboard</title>
  </head>
  <body>
    <main>
      <h1>{operator.name} — Dashboard</h1>

      <section>
        <h2>Active Job</h2>
        <div id="active-job">Loading...</div>
      </section>

      <section>
        <h2>Next Job</h2>
        <div id="current-job">Loading...</div>
      </section>
    </main>

    <script define:vars={{ operatorSlug: operator.slug }}>
      let techToken = "";
      try { techToken = sessionStorage.getItem("planck.tech_token") || ""; } catch {}
      const headers = {
        accept: "application/json",
        "x-operator-slug": operatorSlug,
        "x-tech-token": techToken,
      };

      function esc(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function jobCard(job, linkLabel, linkHref) {
        const snap = job.packet?.intake_snapshot?.data || {};
        const contact = snap.contact || {};
        const asset = snap.asset || {};
        const request = snap.request || {};
        const status = job.state?.status || "unknown";
        const customer = esc(contact.name || "—");
        const assetDesc = esc(asset.details || asset.class || "—");
        const tier = esc(request.tier || request.tier_id || "—");
        return `<dl style="margin:0;display:grid;grid-template-columns:max-content 1fr;gap:4px 12px;font-size:14px">
          <dt style="color:#6b7280">Customer</dt><dd style="margin:0">${customer}</dd>
          <dt style="color:#6b7280">Asset</dt><dd style="margin:0">${assetDesc}</dd>
          <dt style="color:#6b7280">Tier</dt><dd style="margin:0">${tier}</dd>
          <dt style="color:#6b7280">Status</dt><dd style="margin:0">${esc(status)}</dd>
          <dt style="color:#6b7280">Job ID</dt><dd style="margin:0;font-size:12px;color:#9ca3af">${esc(job.job_id)}</dd>
        </dl>
        <p style="margin:12px 0 0"><a href="${esc(linkHref)}">${esc(linkLabel)} →</a></p>`;
      }

      async function loadActive() {
        const el = document.getElementById("active-job");
        try {
          const res = await fetch("/api/job/active", { method: "GET", headers });
          const data = await res.json().catch(() => null);
          if (!data?.ok) {
            el.textContent = "Error loading active job.";
            return;
          }
          if (data.job) {
            const href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(data.job.job_id)}`;
            el.innerHTML = jobCard(data.job, "Continue Active Job", href);
          } else {
            el.textContent = "No active job.";
          }
        } catch {
          el.textContent = "Error loading active job.";
        }
      }

      async function loadCurrent() {
        const el = document.getElementById("current-job");
        try {
          const res = await fetch("/api/job/current", { method: "GET", headers });
          const data = await res.json().catch(() => null);
          if (!data?.ok) {
            el.textContent = "Error loading next job.";
            return;
          }
          if (data.job) {
            const href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(data.job.job_id)}`;
            el.innerHTML = jobCard(data.job, "Open Next Job", href);
          } else {
            el.textContent = "No queued jobs.";
          }
        } catch {
          el.textContent = "Error loading next job.";
        }
      }

      loadActive();
      loadCurrent();
    </script>
  </body>
</html>
