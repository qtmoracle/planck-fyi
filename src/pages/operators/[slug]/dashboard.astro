---
import { operators, getOperatorBySlug } from "../../../data/operators";

export function getStaticPaths() {
  return operators.map((op) => ({ params: { slug: op.slug } }));
}

const { slug } = Astro.params;
const operator = getOperatorBySlug(slug ?? "");
if (!operator) {
  throw new Error(`Operator not found: ${slug}`);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{operator.name} — Dashboard</title>
  </head>
  <body class="bg-white text-black min-h-screen">
    <main class="mx-auto max-w-2xl px-4 py-10 sm:px-6">

      <header class="mb-8">
        <p class="text-xs uppercase tracking-widest text-black/30">Operator Control Plane</p>
        <h1 class="mt-1 text-2xl font-semibold">{operator.name}</h1>
        <p class="mt-1 text-sm text-black/50">{operator.surface} · {operator.regionName}</p>
      </header>

      <div class="grid gap-5">

        <!-- Lifecycle Rail -->
        <div class="rounded-2xl border border-black/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-4">Job Lifecycle</p>
          <div id="lifecycle-rail" class="flex items-start gap-0 overflow-x-auto pb-1">
            <!-- rendered by JS -->
          </div>
        </div>

        <!-- Now — Next Action -->
        <div id="next-action-card" class="rounded-2xl border border-black p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-3">Now</p>
          <div id="next-action-body" class="text-sm text-black/40">Loading…</div>
        </div>

        <!-- Active Job -->
        <div class="rounded-2xl border border-black/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-3">Active Job</p>
          <div id="active-job" class="text-sm text-black/40">Checking…</div>
        </div>

        <!-- Ready to Claim -->
        <div class="rounded-2xl border border-black/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-3">Ready to Claim</p>
          <div id="current-job" class="text-sm text-black/40">Checking…</div>
        </div>

        <!-- Completed Jobs -->
        <div class="rounded-2xl border border-black/10 p-5">
          <div class="flex items-baseline justify-between mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-black/30">Completed</p>
            <span id="completed-count" class="text-xs text-black/25"></span>
          </div>
          <div id="completed-jobs" class="text-sm text-black/40">Checking…</div>
        </div>

        <!-- Revenue Snapshot -->
        <div class="rounded-2xl border border-black/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-4">Revenue Snapshot</p>
          <div id="revenue-snapshot" class="text-sm text-black/40">Loading…</div>
        </div>

        <!-- --- OMNI SECTION START --- -->
        <div class="rounded-2xl border border-black/10 p-5">
          <div class="flex items-baseline justify-between mb-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-black/30">Omni Suggestions</p>
            <span class="text-xs text-black/20">v0.01</span>
          </div>
          <div class="mb-3 flex gap-2">
            <input
              id="omni-intake-id"
              type="text"
              placeholder="Intake ID…"
              class="flex-1 rounded-xl border border-black/20 px-3 py-2 text-xs font-mono"
            />
            <button
              id="omni-fetch-btn"
              type="button"
              class="rounded-xl border border-black/20 px-3 py-2 text-xs text-black/60 hover:border-black/40 hover:text-black transition-colors whitespace-nowrap"
            >Get Suggestions</button>
          </div>
          <div id="omni-suggestions-list" class="grid gap-2">
            <!-- rendered by JS -->
          </div>
          <div id="omni-flags-list" class="mt-2 grid gap-1">
            <!-- flags rendered by JS -->
          </div>
          <p id="omni-status" class="mt-3 text-xs text-black/40 min-h-[1em]"></p>
        </div>
        <!-- --- OMNI SECTION END --- -->

        <!-- --- OMNI ACTIVITY START --- -->
        <div class="rounded-2xl border border-black/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-4">Recent Omni Activity</p>
          <div id="omni-activity-list" class="grid gap-1.5">
            <!-- rendered by JS -->
          </div>
        </div>
        <!-- --- OMNI ACTIVITY END --- -->

        <!-- Token -->
        <div class="rounded-2xl border border-black/10 p-5">
          <p class="text-xs font-semibold uppercase tracking-widest text-black/30 mb-3">TECH Token</p>
          <div class="flex gap-2">
            <input
              id="dashboard-token-input"
              type="password"
              placeholder="Enter TECH token…"
              class="flex-1 rounded-xl border border-black/20 px-3 py-2 text-sm font-mono"
            />
            <button
              id="dashboard-token-save"
              type="button"
              class="rounded-xl border border-black px-4 py-2 text-sm"
            >
              Save
            </button>
          </div>
          <p id="dashboard-token-status" class="mt-2 text-xs text-black/40"></p>
        </div>

      </div>
    </main>

    <script define:vars={{ operatorSlug: operator.slug, operatorSurface: operator.surface }}>

      // ── Token ─────────────────────────────────────────────────────────────────

      function getToken() {
        try { return sessionStorage.getItem("planck.tech_token") || ""; } catch { return ""; }
      }
      function setToken(val) {
        try { sessionStorage.setItem("planck.tech_token", val); } catch {}
      }

      function makeHeaders() {
        return {
          accept: "application/json",
          "x-operator-slug": operatorSlug,
          "x-tech-token": getToken(),
        };
      }

      function esc(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      const tokenInput    = document.getElementById("dashboard-token-input");
      const tokenSaveBtn  = document.getElementById("dashboard-token-save");
      const tokenStatusEl = document.getElementById("dashboard-token-status");

      function updateTokenDisplay() {
        const token = getToken();
        if (tokenInput) tokenInput.value = token;
        if (tokenStatusEl) {
          tokenStatusEl.textContent = token
            ? "Token active."
            : "No token set — enter your TECH token above.";
        }
      }

      tokenSaveBtn?.addEventListener("click", () => {
        const val = String(tokenInput?.value || "").trim();
        setToken(val);
        updateTokenDisplay();
        reload();
      });

      updateTokenDisplay();

      // ── Lifecycle rail ────────────────────────────────────────────────────────

      const LIFECYCLE_STEPS = operatorSurface === "event-coordination"
        ? [
            { key: "queued",      label: "Queued"          },
            { key: "claimed",     label: "Confirmed"       },
            { key: "arrived",     label: "Vendor Arrival"  },
            { key: "in_progress", label: "Event Live"      },
            { key: "evidence",    label: "Breakdown"       },
            { key: "complete",    label: "Closed"          },
          ]
        : [
            { key: "queued",      label: "Queued"      },
            { key: "claimed",     label: "Claimed"     },
            { key: "arrived",     label: "Arrived"     },
            { key: "in_progress", label: "In Progress" },
            { key: "evidence",    label: "Evidence"    },
            { key: "complete",    label: "Complete"    },
          ];

      function resolveLifecycleStep(activeJob, queuedJob) {
        if (!activeJob && queuedJob) return "queued";
        if (!activeJob) return "queued";

        const seStatus      = activeJob.service_event_summary?.status ?? null;
        const payStatus     = activeJob.service_event_summary?.payment_status ?? null;
        const evidenceCount = activeJob.service_event_summary?.evidence_count ?? 0;

        if (!seStatus)                    return "claimed";
        if (seStatus === "created")       return "arrived";
        if (seStatus === "in_progress")   return evidenceCount > 0 ? "evidence" : "in_progress";
        if (seStatus === "completed")     return (payStatus === "paid" || payStatus === "waived") ? "complete" : "evidence";
        return "claimed";
      }

      function renderLifecycleRail(currentKey) {
        const rail = document.getElementById("lifecycle-rail");
        if (!rail) return;

        const currentIdx = LIFECYCLE_STEPS.findIndex(s => s.key === currentKey);

        rail.innerHTML = LIFECYCLE_STEPS.map((step, idx) => {
          const isPast    = idx < currentIdx;
          const isCurrent = idx === currentIdx;

          const dotClass = isCurrent
            ? "h-2.5 w-2.5 rounded-full bg-black flex-shrink-0"
            : isPast
              ? "h-2 w-2 rounded-full bg-black/30 flex-shrink-0"
              : "h-2 w-2 rounded-full border border-black/20 flex-shrink-0";

          const labelClass = isCurrent
            ? "text-[11px] font-semibold text-black mt-1.5 whitespace-nowrap"
            : isPast
              ? "text-[11px] text-black/30 mt-1.5 whitespace-nowrap"
              : "text-[11px] text-black/20 mt-1.5 whitespace-nowrap";

          const connector = idx < LIFECYCLE_STEPS.length - 1
            ? `<div class="h-px flex-1 min-w-[8px] mt-[5px] self-start ${isPast || isCurrent ? "bg-black/20" : "bg-black/08"}"></div>`
            : "";

          return `<div class="flex flex-col items-center min-w-0"><div class="${dotClass}"></div><span class="${labelClass}">${esc(step.label)}</span></div>${connector}`;
        }).join("");
      }

      // ── Next action resolver ──────────────────────────────────────────────────

      const isEvent = operatorSurface === "event-coordination";

      function resolveNextAction(activeJob, queuedJob) {
        if (activeJob) {
          const seStatus      = activeJob.service_event_summary?.status ?? null;
          const payStatus     = activeJob.service_event_summary?.payment_status ?? null;
          const evidenceCount = activeJob.service_event_summary?.evidence_count ?? 0;
          const href          = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(activeJob.job_id)}`;

          if (!seStatus) return {
            label:    isEvent ? "Open the active event to begin coordination." : "Open your active job to begin execution.",
            sublabel: "ServiceEvent not yet initialized.",
            cta: isEvent ? "Open Event →" : "Open Job →", href,
          };
          if (seStatus === "created") return {
            label:    isEvent ? "Vendors are arriving. Log arrival and begin event setup." : "You have arrived on site. Mark your arrival and start service.",
            sublabel: isEvent ? "Next: vendor arrival photo → start setup." : "Next: arrival photo → start service.",
            cta: isEvent ? "Start Setup →" : "Start Service →", href,
          };
          if (seStatus === "in_progress" && evidenceCount === 0) return {
            label:    isEvent ? "Event is live. Capture setup or milestone photos." : "Service is in progress. Capture before photos now.",
            sublabel: "No evidence uploaded yet.",
            cta: "Add Evidence →", href,
          };
          if (seStatus === "in_progress") return {
            label:    isEvent ? "Event in progress. Close when breakdown is complete." : "Service in progress. Complete when ready.",
            sublabel: `${evidenceCount} photo${evidenceCount === 1 ? "" : "s"} captured.`,
            cta: isEvent ? "Continue Event →" : "Continue Job →", href,
          };
          if (seStatus === "completed" && (payStatus === "unpaid" || !payStatus)) return {
            label:    isEvent ? "Event closed. Record final payment before archiving." : "Service complete. Record payment before closing.",
            sublabel: "Payment not yet recorded.",
            cta: "Record Payment →", href,
          };
          return {
            label:    isEvent ? "Event closed and payment recorded. Record ready." : "Service complete and payment recorded. Job ready to close.",
            sublabel: `Payment: ${payStatus}.`,
            cta: "View Record →", href,
          };
        }

        if (queuedJob) return {
          label:    isEvent ? "An event request is waiting. Confirm it to begin." : "A job is waiting. Claim it to begin.",
          sublabel: isEvent ? "No active event — queue has a request." : "No active job — queue has work.",
          cta: isEvent ? "Confirm & Start →" : "Claim & Start →", href: null, isClaim: true,
        };

        return {
          label:    isEvent ? "All clear. No active events or pending requests." : "All clear. No active jobs or pending queue.",
          sublabel: "Waiting for new requests.",
          cta: null, href: null,
        };
      }

      function renderNextAction(action) {
        const body = document.getElementById("next-action-body");
        if (!body) return;

        let ctaHtml = "";
        if (action.cta && action.href) {
          ctaHtml = `<p class="mt-4"><a href="${esc(action.href)}" class="inline-block rounded-xl border border-black px-4 py-2 text-sm font-medium">${esc(action.cta)}</a></p>`;
        } else if (action.cta && action.isClaim) {
          ctaHtml = `<div class="mt-4 flex items-center gap-3">
            <button id="next-action-claim-btn" type="button" class="rounded-xl border border-black px-4 py-2 text-sm font-medium">${esc(action.cta)}</button>
            <span id="next-action-claim-error" class="text-sm text-red-600"></span>
          </div>`;
        }

        body.innerHTML = `
          <p class="text-base font-medium text-black leading-snug">${esc(action.label)}</p>
          ${action.sublabel ? `<p class="mt-1 text-sm text-black/50">${esc(action.sublabel)}</p>` : ""}
          ${ctaHtml}
        `;

        if (action.isClaim) {
          document.getElementById("next-action-claim-btn")?.addEventListener("click", () => {
            const btn = document.getElementById("next-action-claim-btn");
            if (btn) { btn.disabled = true; btn.textContent = "Claiming…"; }
            claimJob().catch(() => {
              if (btn) { btn.disabled = false; btn.textContent = "Claim & Start →"; }
            });
          });
        }
      }

      // ── Job card helper ───────────────────────────────────────────────────────

      function jobSummary(job) {
        const snap    = job.packet?.intake_snapshot?.data || {};
        const contact = snap.contact || {};
        const asset   = snap.asset || {};
        const request = snap.request || {};
        return `<div class="grid gap-1">
          <p class="font-medium text-black">${esc(contact.name || "—")}</p>
          <p class="text-sm text-black/60">${esc(asset.details || asset.class || "—")} · ${esc(request.tier || request.tier_id || "—")}</p>
          <p class="mt-1 text-xs text-black/25 font-mono">${esc(job.job_id || "")}</p>
        </div>`;
      }

      // ── Claim ─────────────────────────────────────────────────────────────────

      async function claimJob() {
        const res  = await fetch("/api/job/claim", {
          method: "POST",
          headers: { accept: "application/json", "x-tech-token": getToken(), "x-operator-slug": operatorSlug },
        });
        const data = await res.json().catch(() => null);
        if (!res.ok || !data?.ok || !data?.job) {
          const errEl = document.getElementById("claim-error") || document.getElementById("next-action-claim-error");
          if (errEl) errEl.textContent = "Failed: " + esc(data?.error || String(res.status));
          throw new Error(data?.error || "claim_failed");
        }
        window.location.href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(data.job.job_id)}`;
      }

      // ── Loaders ───────────────────────────────────────────────────────────────

      async function loadActive() {
        const el = document.getElementById("active-job");
        try {
          const res  = await fetch("/api/job/active", { method: "GET", headers: makeHeaders() });
          const data = await res.json().catch(() => null);
          if (!data?.ok) { if (el) el.textContent = "Could not load active job."; return null; }

          const job = data.job ?? null;

          if (job) {
            const se   = job.service_event_summary || {};
            const href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(job.job_id)}`;
            if (el) el.innerHTML = `${jobSummary(job)}
              <p class="mt-2 text-xs text-black/40">SE: ${esc(se.status || "not started")} · ${se.evidence_count ?? 0} photo${se.evidence_count === 1 ? "" : "s"}</p>
              <p class="mt-3"><a href="${esc(href)}" class="inline-block rounded-xl border border-black px-4 py-2 text-sm font-medium">Open Job →</a></p>`;
          } else {
            if (el) el.innerHTML = `<p class="text-black/30 italic text-sm">No active job.</p>`;
          }
          return job;
        } catch {
          if (el) el.textContent = "Error — check connection.";
          return null;
        }
      }

      async function loadCurrent() {
        const el = document.getElementById("current-job");
        try {
          const res  = await fetch("/api/job/current", { method: "GET", headers: makeHeaders() });
          const data = await res.json().catch(() => null);
          if (!data?.ok) { if (el) el.textContent = "Could not load queue."; return null; }

          const job = data.job ?? null;

          if (job) {
            if (el) el.innerHTML = `${jobSummary(job)}
              <div class="mt-4 flex items-center gap-3">
                <button id="claim-btn" type="button" class="rounded-xl border border-black px-4 py-2 text-sm font-medium">Claim &amp; Start →</button>
                <span id="claim-error" class="text-sm text-red-600"></span>
              </div>`;
            document.getElementById("claim-btn")?.addEventListener("click", () => {
              const btn = document.getElementById("claim-btn");
              if (btn) { btn.disabled = true; btn.textContent = "Claiming…"; }
              claimJob().catch(() => {
                if (btn) { btn.disabled = false; btn.textContent = "Claim & Start →"; }
              });
            });
          } else {
            if (el) el.innerHTML = `<p class="text-black/30 italic text-sm">Queue is empty.</p>`;
          }
          return job;
        } catch {
          if (el) el.textContent = "Error — check connection.";
          return null;
        }
      }

      async function loadCompleted() {
        const el      = document.getElementById("completed-jobs");
        const countEl = document.getElementById("completed-count");
        try {
          const res  = await fetch("/api/job/completed", { method: "GET", headers: makeHeaders() });
          const data = await res.json().catch(() => null);
          if (!data?.ok) { if (el) el.textContent = "Could not load completed jobs."; return; }

          const jobs = data.jobs || [];
          if (countEl) countEl.textContent = jobs.length ? `${jobs.length} job${jobs.length === 1 ? "" : "s"}` : "";

          if (!jobs.length) {
            if (el) el.innerHTML = `<p class="text-black/30 italic text-sm">No completed jobs yet.</p>`;
            return;
          }

          function paymentBadge(status) {
            const map = {
              paid:    ["Paid",    "bg-green-50 text-green-700"],
              partial: ["Partial", "bg-yellow-50 text-yellow-700"],
              waived:  ["Waived",  "bg-blue-50 text-blue-600"],
              unpaid:  ["Unpaid",  "bg-red-50 text-red-600"],
            };
            const [label, cls] = map[status] || ["—", "text-black/30"];
            return `<span class="inline-block rounded-md px-2 py-0.5 text-xs font-medium ${cls}">${label}</span>`;
          }

          if (el) el.innerHTML = jobs.map((job) => {
            const snap    = job.packet?.intake_snapshot?.data || {};
            const contact = snap.contact || {};
            const asset   = snap.asset || {};
            const req     = snap.request || {};
            const se      = job.service_event_summary || {};
            const photos  = Number(se.evidence_count) || 0;
            const payStatus = String(se.payment_status || "unpaid");
            const amount  = typeof se.amount_collected === "number" ? ` · $${se.amount_collected.toFixed(2)}` : "";
            const completedAt = job.state?.completed_at
              ? new Date(job.state.completed_at).toLocaleString(undefined, {
                  month: "short", day: "numeric", year: "numeric", hour: "numeric", minute: "2-digit",
                })
              : "—";
            const href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(job.job_id)}`;

            return `<div class="rounded-xl border border-black/8 p-4 grid gap-3">
              <div class="flex items-start justify-between gap-3">
                <div class="grid gap-0.5 min-w-0">
                  <p class="font-semibold text-black leading-tight">${esc(contact.name || "—")}</p>
                  <p class="text-sm text-black/60">${esc(asset.details || asset.class || "—")}</p>
                </div>
                <a href="${esc(href)}" class="shrink-0 rounded-lg border border-black/15 px-3 py-1 text-xs font-medium text-black/60 hover:text-black hover:border-black/40 transition-colors">View →</a>
              </div>
              <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-black/50">
                <span>${esc(se.tier || req.tier_id || req.tier || "—")}</span>
                <span>${esc(req.service_area || se.surface || "—")}</span>
              </div>
              <div class="h-px bg-black/5"></div>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-black/40">
                <span>${esc(completedAt)}</span>
                <span>${photos} photo${photos === 1 ? "" : "s"}</span>
                <span>${paymentBadge(payStatus)}${esc(amount)}</span>
              </div>
            </div>`;
          }).join("");

          // ── Revenue Snapshot ──────────────────────────────────────────────────
          // Derived entirely from the jobs array already loaded above.
          // amount_collected is null when no ServiceEvent exists — only non-null values
          // are summed, so totals reflect recorded payments only.
          renderRevenueSnapshot(jobs);

        } catch {
          if (el) el.textContent = "Error — check connection.";
          const rev = document.getElementById("revenue-snapshot");
          if (rev) rev.textContent = "Could not load revenue data.";
        }
      }

      function renderRevenueSnapshot(jobs) {
        const el = document.getElementById("revenue-snapshot");
        if (!el) return;

        const total     = jobs.length;
        const paid      = jobs.filter(j => ["paid","partial","waived"].includes(String(j.service_event_summary?.payment_status || "")));
        const unpaid    = jobs.filter(j => {
          const s = String(j.service_event_summary?.payment_status || "");
          return s === "unpaid" || s === "";
        });
        const withAmount = jobs.filter(j => typeof j.service_event_summary?.amount_collected === "number");
        const totalCollected = withAmount.reduce((sum, j) => sum + j.service_event_summary.amount_collected, 0);
        const avgCollected   = withAmount.length > 0 ? totalCollected / withAmount.length : null;

        if (total === 0) {
          el.innerHTML = `<p class="text-black/30 italic">No completed jobs yet.</p>`;
          return;
        }

        const fmt = (n) => `$${n.toFixed(2)}`;
        const note = withAmount.length < total
          ? `<p class="mt-3 text-xs text-black/25">Amount reflects ${withAmount.length} of ${total} job${total === 1 ? "" : "s"} with recorded payment.</p>`
          : "";

        el.innerHTML = `
          <div class="grid grid-cols-2 gap-x-6 gap-y-3">
            <div>
              <p class="text-xs text-black/30 mb-0.5">Completed</p>
              <p class="text-lg font-semibold text-black">${total}</p>
            </div>
            <div>
              <p class="text-xs text-black/30 mb-0.5">Paid / Settled</p>
              <p class="text-lg font-semibold text-black">${paid.length}</p>
            </div>
            <div>
              <p class="text-xs text-black/30 mb-0.5">Unpaid</p>
              <p class="text-lg font-semibold ${unpaid.length > 0 ? "text-red-500" : "text-black"}">${unpaid.length}</p>
            </div>
            <div>
              <p class="text-xs text-black/30 mb-0.5">Total Collected</p>
              <p class="text-lg font-semibold text-black">${withAmount.length > 0 ? fmt(totalCollected) : "—"}</p>
            </div>
            <div>
              <p class="text-xs text-black/30 mb-0.5">Avg per Job</p>
              <p class="text-lg font-semibold text-black">${avgCollected !== null ? fmt(avgCollected) : "—"}</p>
            </div>
          </div>
          ${note}
        `;
      }

      // ── Omni ─────────────────────────────────────────────────────────────────
      // --- OMNI SECTION START ---

      function getAgentToken() {
        try { return sessionStorage.getItem("planck.agent_token") || ""; } catch { return ""; }
      }

      const OMNI_SUGGESTIONS = [
        { type: "approve_intake",    label: "Approve Intake"    },
        { type: "request_more_info", label: "Request More Info" },
        { type: "create_job",        label: "Create Job"        },
      ];

      function renderOmniSuggestions() {
        const list = document.getElementById("omni-suggestions-list");
        if (!list) return;

        if (!OMNI_SUGGESTIONS.length) {
          list.innerHTML = `<p class="text-sm text-black/30 italic">No suggestions available.</p>`;
          return;
        }

        list.innerHTML = OMNI_SUGGESTIONS.map((s) =>
          `<button
             type="button"
             data-omni-action="${esc(s.type)}"
             class="w-full text-left rounded-xl border border-black/15 px-4 py-2.5 text-sm text-black/70 hover:border-black/40 hover:text-black transition-colors"
           >${esc(s.label)}</button>`
        ).join("");

        list.querySelectorAll("[data-omni-action]").forEach((btn) => {
          btn.addEventListener("click", () => handleOmniAction(btn.dataset.omniAction));
        });
      }

      async function handleOmniAction(type, triggerBtn) {
        const statusEl   = document.getElementById("omni-status");
        const intakeId   = String(document.getElementById("omni-intake-id")?.value || "").trim();
        const agentToken = getAgentToken();

        function setStatus(msg) {
          if (statusEl) statusEl.textContent = msg;
        }

        function setBusy(busy) {
          if (!triggerBtn) return;
          triggerBtn.disabled = busy;
          triggerBtn.style.opacity = busy ? "0.5" : "";
        }

        function markDone(label) {
          if (!triggerBtn) return;
          triggerBtn.disabled = true;
          triggerBtn.style.opacity = "0.4";
          // replace inner text while preserving the priority badge span
          const badge = triggerBtn.querySelector("span");
          triggerBtn.textContent = "";
          if (badge) triggerBtn.appendChild(badge);
          triggerBtn.append(label);
        }

        if (type === "approve_intake") {
          if (!intakeId) { setStatus("Enter an Intake ID first."); return; }
          setStatus("Approving intake…");
          setBusy(true);
          try {
            const res  = await fetch("/api/agent/intake/queue", {
              method: "POST",
              headers: { "content-type": "application/json", "x-agent-token": agentToken },
              body: JSON.stringify({ intake_id: intakeId }),
            });
            const data = await res.json().catch(() => null);
            console.log("[omni] approve_intake", res.status, data);
            if (res.ok) {
              const alreadyDone = data?.note === "already_approved";
              setStatus(alreadyDone ? `Intake already approved: ${intakeId}` : `Intake approved.`);
              markDone(alreadyDone ? "Already Approved" : "Approved");
              appendOmniLog({ intakeId, event: "approve_intake", message: `Intake approved: ${intakeId}`, status: "success" });
            } else {
              const errMsg = data?.error || String(res.status);
              setStatus(`Action failed — ${esc(errMsg)}`);
              setBusy(false);
              appendOmniLog({ intakeId, event: "action_failed", message: `approve_intake failed: ${errMsg}`, status: "error" });
            }
          } catch (err) {
            console.log("[omni] approve_intake error", err);
            setStatus("Action failed — see console.");
            setBusy(false);
            appendOmniLog({ intakeId, event: "action_failed", message: "approve_intake error — see console", status: "error" });
          }
          return;
        }

        if (type === "create_job") {
          if (!intakeId) { setStatus("Enter an Intake ID first."); return; }
          setStatus("Creating job…");
          setBusy(true);
          try {
            const res  = await fetch(`/api/agent/job/create/${encodeURIComponent(intakeId)}`, {
              method: "POST",
              headers: { "content-type": "application/json", "x-agent-token": agentToken },
              body: JSON.stringify({ operator_slug: operatorSlug }),
            });
            const data = await res.json().catch(() => null);
            console.log("[omni] create_job", res.status, data);
            if (res.ok) {
              setStatus(`Job created: ${esc(data?.job_id || intakeId)}`);
              markDone("Created");
              appendOmniLog({ intakeId, event: "create_job", message: `Job created: ${data?.job_id || intakeId}`, status: "success" });
              reload();
            } else {
              const errMsg = data?.error || String(res.status);
              setStatus(`Action failed — ${esc(errMsg)}`);
              setBusy(false);
              appendOmniLog({ intakeId, event: "action_failed", message: `create_job failed: ${errMsg}`, status: "error" });
            }
          } catch (err) {
            console.log("[omni] create_job error", err);
            setStatus("Action failed — see console.");
            setBusy(false);
            appendOmniLog({ intakeId, event: "action_failed", message: "create_job error — see console", status: "error" });
          }
          return;
        }

        if (type === "request_more_info") {
          // No endpoint configured — log only
          console.log("[omni] request_more_info — no endpoint, logging only. intake_id:", intakeId || "(none)");
          setStatus("Request more info logged.");
          markDone("Logged");
          appendOmniLog({ intakeId: intakeId || undefined, event: "request_more_info", message: `Request more info logged${intakeId ? `: ${intakeId}` : ""}`, status: "info" });
          return;
        }

        console.log("[omni] unknown action:", type);
      }

      // Fetch real suggestions from omni ingest, using job packet as intake source
      async function fetchOmniSuggestions() {
        const statusEl  = document.getElementById("omni-status");
        const intakeId  = String(document.getElementById("omni-intake-id")?.value || "").trim();

        function setStatus(msg) { if (statusEl) statusEl.textContent = msg; }

        if (!intakeId) { setStatus("Enter an Intake ID first."); return; }

        setStatus("Fetching…");

        // Step 1: try to load the intake payload from the job packet (job_id = job_${intakeId}).
        // This is the only frontend-accessible path to the intake packet without Basic Auth.
        // Falls back to a minimal payload if the job doesn't exist yet.
        let intakePayload = { id: intakeId };
        try {
          const jobRes  = await fetch(`/api/job/by_id/${encodeURIComponent("job_" + intakeId)}`, {
            method: "GET",
            headers: { accept: "application/json", "x-tech-token": getToken(), "x-operator-slug": operatorSlug },
          });
          if (jobRes.ok) {
            const jobData  = await jobRes.json().catch(() => null);
            const snapshot = jobData?.job?.packet?.intake_snapshot;
            if (snapshot && typeof snapshot === "object") {
              intakePayload = snapshot; // full intake packet from job packet
            }
          }
          // If 404 (no job yet) or token missing, intakePayload stays minimal —
          // omni will still fire and return field-quality flags, which is useful.
        } catch {
          // network error — proceed with minimal payload
        }

        // Step 2: call omni ingest with the intake payload
        const agentToken = getAgentToken();
        try {
          const omniRes  = await fetch("/api/omni/ingest", {
            method: "POST",
            headers: { "content-type": "application/json", "x-agent-token": agentToken },
            body: JSON.stringify({ type: "intake_created", payload: intakePayload }),
          });
          const omniData = await omniRes.json().catch(() => null);
          console.log("[omni] ingest response", omniRes.status, omniData);

          if (!omniRes.ok || !omniData?.ok) {
            setStatus(omniData?.error === "unauthorized"
              ? "Agent token required — set planck.agent_token in sessionStorage."
              : `Omni error: ${esc(omniData?.error || String(omniRes.status))}`);
            return;
          }

          const suggestions   = Array.isArray(omniData.suggestions) ? omniData.suggestions : [];
          const flags         = Array.isArray(omniData.flags)       ? omniData.flags       : [];
          const qualityScore  = typeof omniData.quality_score === "number" ? omniData.quality_score : null;

          renderOmniResults(suggestions, flags);
          const scoreStr = qualityScore !== null ? ` · Quality: ${qualityScore}/100` : "";
          setStatus(suggestions.length
            ? `${suggestions.length} suggestion${suggestions.length === 1 ? "" : "s"}${flags.length ? ` · ${flags.length} flag${flags.length === 1 ? "" : "s"}` : ""}${scoreStr}`
            : "No suggestions returned.");
          appendOmniLog({ intakeId, event: "suggestions_loaded", message: `Loaded Omni suggestions for intake ${intakeId}`, status: "info" });
        } catch (err) {
          console.log("[omni] ingest error", err);
          setStatus("Error calling omni — see console.");
        }
      }

      // Render real omni suggestions + flags, preserving existing action handlers
      function renderOmniResults(suggestions, flags) {
        const list    = document.getElementById("omni-suggestions-list");
        const flagsEl = document.getElementById("omni-flags-list");

        if (list) {
          if (!suggestions.length) {
            list.innerHTML = `<p class="text-sm text-black/30 italic">No suggestions available.</p>`;
          } else {
            const labelMap = {
              approve_intake:             "Approve Intake",
              create_job:                 "Create Job",
              request_more_info:          "Request More Info",
              follow_up_customer:         "Follow Up with Customer",
              generate_media_pack:        "Generate Media Pack",
              assign_operator:            "Assign Operator",
              notify_operator:            "Notify Operator",
              schedule_job:               "Schedule Job",
              confirm_payment:            "Confirm Payment",
              deliver_record_to_customer: "Deliver Record",
              archive_service_record:     "Archive Record",
            };
            const actionable = new Set(["approve_intake", "create_job", "request_more_info"]);

            const priorityBadge = (p) => {
              if (p === "high")   return `<span class="text-[10px] font-semibold tracking-wide text-black/50 mr-2">[HIGH]</span>`;
              if (p === "medium") return `<span class="text-[10px] font-semibold tracking-wide text-black/30 mr-2">[MED]</span>`;
              return                     `<span class="text-[10px] font-semibold tracking-wide text-black/20 mr-2">[LOW]</span>`;
            };

            list.innerHTML = suggestions.map((s) => {
              const actionType = String(s.action || "");
              const label      = String(s.label || labelMap[actionType] || actionType);
              const badge      = priorityBadge(s.priority);
              if (actionable.has(actionType)) {
                return `<button type="button" data-omni-action="${esc(actionType)}"
                  class="w-full text-left rounded-xl border border-black/15 px-4 py-2.5 text-sm text-black/70 hover:border-black/40 hover:text-black transition-colors"
                >${badge}${esc(label)}</button>`;
              }
              return `<p class="px-1 py-1.5 text-sm text-black/40">${badge}${esc(label)}</p>`;
            }).join("");

            list.querySelectorAll("[data-omni-action]").forEach((btn) => {
              btn.addEventListener("click", () => handleOmniAction(btn.dataset.omniAction, btn));
            });
          }
        }

        if (flagsEl) {
          flagsEl.innerHTML = flags.length
            ? flags.map((f) => {
                const isHigh = f.priority === "high" || f.type === "warning";
                const color  = isHigh ? "text-amber-600" : "text-black/40";
                const icon   = isHigh ? "⚠" : "·";
                return `<p class="text-xs ${color} px-1">${icon} ${esc(f.label || f.field || "flag")}</p>`;
              }).join("")
            : "";
        }

        // Persist results to memory keyed by current intake ID
        const _saveId = String(document.getElementById("omni-intake-id")?.value || "").trim();
        saveOmniMemory(_saveId, suggestions, flags);
      }

      document.getElementById("omni-fetch-btn")?.addEventListener("click", fetchOmniSuggestions);

      // --- OMNI MEMORY START ---

      function omniMemoryKey(intakeId) {
        return `omni:${intakeId}`;
      }

      function saveOmniMemory(intakeId, suggestions, flags) {
        if (!intakeId) return;
        try {
          sessionStorage.setItem(omniMemoryKey(intakeId), JSON.stringify({
            suggestions: suggestions || [],
            flags: flags || [],
            timestamp: Date.now(),
          }));
        } catch { /* storage full or unavailable — degrade silently */ }
      }

      function loadOmniMemory(intakeId) {
        if (!intakeId) return null;
        try {
          const raw = sessionStorage.getItem(omniMemoryKey(intakeId));
          if (!raw) return null;
          const parsed = JSON.parse(raw);
          // Validate shape — must have a suggestions array
          if (!Array.isArray(parsed?.suggestions)) return null;
          return parsed;
        } catch {
          return null; // malformed storage — ignore
        }
      }

      function restoreOmniMemory(intakeId) {
        const statusEl = document.getElementById("omni-status");
        function setStatus(msg) { if (statusEl) statusEl.textContent = msg; }

        if (!intakeId) return;

        const mem = loadOmniMemory(intakeId);
        if (!mem) {
          setStatus("No cached suggestions — fetch to analyze.");
          return;
        }

        renderOmniResults(mem.suggestions, mem.flags || []);
        setStatus("Loaded cached suggestions.");
      }

      // Restore on input change (fires on blur / Enter — full ID expected)
      document.getElementById("omni-intake-id")?.addEventListener("change", (e) => {
        const intakeId = String(e.target?.value || "").trim();
        restoreOmniMemory(intakeId);
      });

      // Restore on page load if input already has a value (e.g. browser form restore)
      const _loadIntakeId = String(document.getElementById("omni-intake-id")?.value || "").trim();
      if (_loadIntakeId) restoreOmniMemory(_loadIntakeId);

      // --- OMNI MEMORY END ---

      // --- OMNI ACTIVITY START ---

      const OMNI_LOG_KEY = `omni-log:${operatorSlug}`;
      const OMNI_LOG_MAX = 20;

      function readOmniLog() {
        try {
          const raw = sessionStorage.getItem(OMNI_LOG_KEY);
          if (!raw) return [];
          const parsed = JSON.parse(raw);
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }

      function appendOmniLog(entry) {
        const log = readOmniLog();
        log.unshift({ timestamp: Date.now(), ...entry });
        if (log.length > OMNI_LOG_MAX) log.length = OMNI_LOG_MAX;
        try { sessionStorage.setItem(OMNI_LOG_KEY, JSON.stringify(log)); } catch {}
        renderOmniActivity();
      }

      function renderOmniActivity() {
        const el = document.getElementById("omni-activity-list");
        if (!el) return;
        const log = readOmniLog();
        if (!log.length) {
          el.innerHTML = `<p class="text-xs text-black/25 italic">No Omni activity yet.</p>`;
          return;
        }
        el.innerHTML = log.map((e) => {
          const time  = new Date(e.timestamp).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
          const color = e.status === "success" ? "text-black/60"
                      : e.status === "error"   ? "text-red-500"
                      :                          "text-black/35";
          const dot   = e.status === "success" ? "●" : e.status === "error" ? "✕" : "·";
          return `<p class="text-xs ${color} flex gap-2"><span class="shrink-0 w-10 text-black/20">${esc(time)}</span><span class="shrink-0">${dot}</span><span>${esc(e.message)}</span></p>`;
        }).join("");
      }

      renderOmniActivity(); // render on load from sessionStorage

      // --- OMNI ACTIVITY END ---

      renderOmniSuggestions(); // initial fallback render (static buttons — overridden by memory restore if available)

      // --- OMNI SECTION END ---

      // ── Boot ─────────────────────────────────────────────────────────────────

      async function reload() {
        const [activeJob, queuedJob] = await Promise.all([loadActive(), loadCurrent()]);
        loadCompleted();
        const step   = resolveLifecycleStep(activeJob, queuedJob);
        const action = resolveNextAction(activeJob, queuedJob);
        renderLifecycleRail(step);
        renderNextAction(action);
      }

      reload();
      setInterval(reload, 20000);
    </script>
  </body>
</html>
