---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { operators } from "../../data/operators";
import { surfaces } from "../../data/surfaces";

const plannedSurfaces = surfaces.filter((s) => s.status === "planned");
---

<BaseLayout title="Planck Network Operators">
  <main class="py-24">
    <div class="mx-auto max-w-content px-4 sm:px-6">
      <header class="grid gap-8 lg:grid-cols-[1.2fr_.8fr] lg:items-start">
        <div class="max-w-3xl">
          <p class="text-xs tracking-wide text-text/70">
            planck service router
          </p>

          <h1 class="mt-4 text-4xl sm:text-5xl font-semibold tracking-tightest leading-tight">
            network operators
          </h1>

          <p class="mt-6 max-w-2xl text-muted leading-relaxed">
            independent operators delivering structured service protocols
            through the planck routing infrastructure.
          </p>

          <p class="mt-4 text-sm text-text/60">
            {operators.length} active operator{operators.length !== 1 ? "s" : ""}
          </p>
        </div>

        <div class="relative overflow-hidden border border-border bg-bg/60 p-6">
          <img
            src="/images/network-grid.svg"
            alt="Operator network"
            class="pointer-events-none absolute inset-0 h-full w-full object-cover opacity-10"
            loading="lazy"
          />

          <div class="pointer-events-none absolute inset-0">
            <div class="absolute -right-8 top-0 h-28 w-28 rounded-full bg-accent/10 blur-3xl"></div>
          </div>

          <div class="relative">
            <p class="text-xs tracking-[0.18em] text-text/60 uppercase">
              operator layer
            </p>

            <p class="mt-4 text-sm text-muted leading-relaxed">
              Planck routes discovery toward independent operators without
              replacing their identity, service standards, or execution model.
            </p>

            <div class="mt-6 grid gap-4 sm:grid-cols-2">
              <div class="border border-border/70 bg-white/[0.02] p-4">
                <p class="text-xs tracking-wide text-text/60 uppercase">
                  live operators
                </p>
                <p class="mt-2 text-lg font-medium">
                  {operators.length}
                </p>
              </div>

              <div class="border border-border/70 bg-white/[0.02] p-4">
                <p class="text-xs tracking-wide text-text/60 uppercase">
                  future lanes
                </p>
                <p class="mt-2 text-lg font-medium">
                  {plannedSurfaces.length}
                </p>
              </div>
            </div>
          </div>
        </div>
      </header>

      <section class="mt-16">
        <div class="max-w-3xl">
          <p class="text-xs tracking-[0.18em] text-text/60 uppercase">
            active operators
          </p>
          <h2 class="mt-3 text-2xl font-semibold">
            live nodes on the network
          </h2>
        </div>

        {operators.length === 1 ? (
          <div class="mt-8 max-w-4xl">
            {operators.map((operator) => (
              <a
                href={`/operators/${operator.slug}`}
                class="group relative block overflow-hidden border border-border bg-bg/60 p-6 sm:p-8 md:p-10 hover:border-accent transition-colors"
              >
                <div class="pointer-events-none absolute inset-0">
                  <div class="absolute -right-10 top-0 h-32 w-32 rounded-full bg-accent/10 blur-3xl"></div>
                  <div class="absolute inset-x-0 top-0 h-1 bg-accent/35"></div>
                </div>

                <div class="relative">
                  <img
                    src="/images/detailing-hero.svg"
                    alt={`${operator.name} service surface`}
                    class="mb-6 h-56 w-full rounded border border-border/70 object-cover md:h-72"
                    loading="lazy"
                  />

                  <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex items-center gap-5">
                      <div class="flex h-16 w-28 items-center justify-center border border-border/70 bg-white/[0.02] px-3">
                        <img
                          src={operator.logo}
                          alt={operator.name}
                          class="max-h-10 h-auto w-auto max-w-full object-contain"
                          loading="lazy"
                        />
                      </div>

                      <div>
                        <p class="text-2xl sm:text-3xl font-medium text-text">
                          {operator.name}
                        </p>

                        <p class="mt-1 text-sm text-text/70">
                          {operator.regionName}
                        </p>
                      </div>
                    </div>

                    <div class="shrink-0">
                      <span class="inline-flex border border-border/70 px-3 py-1 text-[11px] uppercase tracking-wide text-text/60">
                        {operator.surface}
                      </span>
                    </div>
                  </div>

                  <p class="mt-8 max-w-2xl text-base text-muted leading-relaxed">
                    {operator.tagline}
                  </p>

                  <div class="mt-8 flex items-center justify-between gap-4 border-t border-border/60 pt-6">
                    <span class="text-sm text-text/60">
                      independent operator node
                    </span>

                    <span class="text-sm text-accent group-hover:translate-x-1 transition-transform">
                      view operator →
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
            {operators.map((operator) => (
              <a
                href={`/operators/${operator.slug}`}
                class="group relative overflow-hidden border border-border bg-bg/60 p-6 hover:border-accent transition-colors"
              >
                <div class="pointer-events-none absolute inset-0">
                  <div class="absolute -right-8 top-0 h-24 w-24 rounded-full bg-accent/10 blur-2xl"></div>
                </div>

                <div class="relative">
                  <img
                    src="/images/detailing-hero.svg"
                    alt={`${operator.name} service surface`}
                    class="mb-5 h-44 w-full rounded border border-border/70 object-cover"
                    loading="lazy"
                  />

                  <div class="flex items-center gap-4">
                    <div class="flex h-14 w-24 items-center justify-center border border-border/70 bg-white/[0.02] px-2">
                      <img
                        src={operator.logo}
                        alt={operator.name}
                        class="max-h-8 h-auto w-auto max-w-full object-contain"
                        loading="lazy"
                      />
                    </div>

                    <div>
                      <p class="text-lg font-medium text-text">
                        {operator.name}
                      </p>

                      <p class="text-sm text-text/70">
                        {operator.regionName}
                      </p>
                    </div>
                  </div>

                  <p class="mt-5 text-sm text-muted leading-relaxed">
                    {operator.tagline}
                  </p>

                  <div class="mt-6 flex items-center justify-between">
                    <span class="border border-border/70 px-3 py-1 text-[11px] uppercase tracking-wide text-text/60">
                      {operator.surface}
                    </span>

                    <span class="text-sm text-accent group-hover:translate-x-1 transition-transform">
                      view operator →
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>

      <section class="mt-20 border-t border-border pt-14">
        <div class="max-w-3xl">
          <p class="text-xs tracking-[0.18em] text-text/60 uppercase">
            planned network expansion
          </p>

          <h2 class="mt-4 text-2xl font-semibold">
            future surface lanes
          </h2>

          <p class="mt-4 text-muted leading-relaxed">
            These are not live operators. They are future network lanes shown here
            to reflect the broader routing vision.
          </p>
        </div>

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {plannedSurfaces.map((surface) => (
            <div class="relative overflow-hidden border border-border bg-bg/60 p-6 opacity-90">
              <div class="pointer-events-none absolute inset-0">
                <div class="absolute left-0 top-0 h-1 w-full bg-accent/35"></div>
                <div class="absolute -right-6 bottom-0 h-20 w-20 rounded-full bg-accent/10 blur-2xl"></div>
              </div>

              <div class="relative">
                <div class="mb-5 overflow-hidden rounded border border-border/70">
                  <img
                    src={surface.image}
                    alt={`${surface.name} surface`}
                    class="h-44 w-full object-cover"
                    loading="lazy"
                  />
                </div>

                <div class="flex items-center justify-between gap-4">
                  <p class="text-lg font-medium text-text">
                    {surface.name.toLowerCase()}
                  </p>

                  <span class="text-xs uppercase tracking-wide text-text/50">
                    planned
                  </span>
                </div>

                <p class="mt-4 text-sm text-muted leading-relaxed">
                  {surface.description}
                </p>

                <div class="mt-6 flex items-center justify-between">
                  <span class="border border-border/70 px-3 py-1 text-[11px] uppercase tracking-wide text-text/60">
                    future surface
                  </span>

                  <span class="text-sm text-muted">
                    coming soon
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
