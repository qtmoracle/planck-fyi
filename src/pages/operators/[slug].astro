---
import { operators, getOperatorBySlug } from "../../data/operators";
import { getOperatorTemplate } from "../../lib/operator-templates";
import SurfaceNavigator from "../../components/SurfaceNavigator.astro";

export function getStaticPaths() {
  return operators.map((operator) => ({
    params: { slug: operator.slug },
  }));
}

const { slug } = Astro.params;
const operator = getOperatorBySlug(slug ?? "");

if (!operator) {
  throw new Error(`Operator not found: ${slug}`);
}

const OperatorTemplate = getOperatorTemplate(operator.template, operator.surface);
const accessState = operator.accessState;
---

{accessState === "suspended" && (
  <div style="background:#fef2f2;border-bottom:1px solid #fecaca;padding:12px 20px;font-size:14px;color:#991b1b;text-align:center;">
    This operator account is suspended. Execution is blocked. Contact support.
  </div>
)}
{accessState === "limited" && (
  <div style="background:#fffbeb;border-bottom:1px solid #fde68a;padding:12px 20px;font-size:14px;color:#92400e;text-align:center;">
    This operator account is in limited mode. Some operations may be restricted.
  </div>
)}

{OperatorTemplate ? (
  <OperatorTemplate operator={operator} />
) : (
  <SurfaceNavigator template={operator.template} surface={operator.surface} />
)}

<script define:vars={{ operatorSlug: operator.slug }}>
  (async () => {
    let techToken = "";
    try { techToken = sessionStorage.getItem("planck.tech_token") || ""; } catch {}
    const headers = { accept: "application/json", "x-operator-slug": operatorSlug, "x-tech-token": techToken };

    const activeRes = await fetch("/api/job/active", { method: "GET", headers }).catch(() => null);
    const activeData = activeRes ? await activeRes.json().catch(() => null) : null;

    if (activeData?.ok && activeData?.job) {
      window.location.href = `/operators/${operatorSlug}/jobs/?job=${encodeURIComponent(activeData.job.job_id)}`;
      return;
    }

    const currentRes = await fetch("/api/job/current", { method: "GET", headers }).catch(() => null);
    const currentData = currentRes ? await currentRes.json().catch(() => null) : null;

    if (currentData?.ok && currentData?.job) {
      window.location.href = `/operators/${operatorSlug}/dashboard`;
    }
  })();
</script>
