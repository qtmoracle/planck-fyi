---
import V1OperatorTemplate from "../../templates/operator/v1.astro";
import { operators, getOperatorBySlug } from "../../data/operators";

export function getStaticPaths() {
  return operators.map((operator) => ({
    params: { slug: operator.slug },
  }));
}

const { slug } = Astro.params;
const operator = getOperatorBySlug(slug ?? "");

if (!operator) {
  throw new Error(`Operator not found: ${slug}`);
}
---

{operator.template === "v1" ? (
  <V1OperatorTemplate operator={operator} />
) : (
  <div class="mx-auto max-w-content px-4 sm:px-6 py-24">
    <p class="text-sm text-text/70">Unknown operator template: {operator.template}</p>
  </div>
)}
